<!--pages/my-orders/my-orders.wxml - 我的订单页面（支持所有角色）-->
<view class="page">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-title">我的订单</view>
    <view class="header-subtitle">查看和管理维修订单</view>
  </view>

  <!-- 状态筛选标签 -->
  <view class="filter-tabs">
    <view
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}"
      data-tab="all"
      bindtap="onTabChange"
    >
      <text class="tab-text">全部</text>
    </view>
    <view
      class="tab-item {{activeTab === 'pending_assessment' ? 'active' : ''}}"
      data-tab="pending_assessment"
      bindtap="onTabChange"
    >
      <text class="tab-text">待接车检查</text>
    </view>
    <view
      class="tab-item {{activeTab === 'awaiting_approval' ? 'active' : ''}}"
      data-tab="awaiting_approval"
      bindtap="onTabChange"
    >
      <text class="tab-text">待审批报价</text>
    </view>
    <view
      class="tab-item {{activeTab === 'in_repair' ? 'active' : ''}}"
      data-tab="in_repair"
      bindtap="onTabChange"
    >
      <text class="tab-text">维修中</text>
    </view>
    <view
      class="tab-item {{activeTab === 'completed' ? 'active' : ''}}"
      data-tab="completed"
      bindtap="onTabChange"
    >
      <text class="tab-text">已完成</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
      <image class="empty-icon svg-icon-xl" src="/images/icons/clipboard.svg" mode="aspectFit" />
      <text class="empty-text">暂无订单</text>
    </view>

    <!-- 订单卡片 -->
    <view
      class="order-card"
      wx:for="{{orders}}"
      wx:key="_id"
      bindtap="onOrderTap"
      data-id="{{item._id}}"
    >
      <!-- 订单状态标签 -->
      <view class="order-status status-{{item.status}}">
        {{item.statusText}}
      </view>

      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-number">{{item.orderNumber}}</view>
        <view class="order-time">{{item.createdAtText}}</view>
      </view>

      <!-- 车辆信息 -->
      <view class="order-vehicle">
        <image class="vehicle-icon svg-icon-lg" src="/images/icons/truck.svg" mode="aspectFit" />
        <view class="vehicle-info">
          <view class="vehicle-plate">{{item.vehicleId.plateNumber}}</view>
          <view class="vehicle-model">{{item.vehicleId.brand}} {{item.vehicleId.model}}</view>
        </view>
      </view>

      <!-- 故障描述 -->
      <view class="order-fault">
        <text class="fault-label">故障：</text>
        <text class="fault-text">{{item.faultDescription}}</text>
      </view>

      <!-- 报价信息（如果有） -->
      <view class="order-quote" wx:if="{{item.quote}}">
        <text class="quote-label">报价：</text>
        <text class="quote-price">¥{{item.quote.total}}</text>
      </view>

      <!-- 进度提示 -->
      <view class="order-progress-hint" wx:if="{{item.nextAction}}">
        <image class="hint-icon svg-icon-md" src="/images/icons/lightbulb.svg" mode="aspectFit" />
        <text class="hint-text">{{item.nextAction}}</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
