<view class="add-container">
  <view class="form-section glass-card">
    <view class="form-item">
      <text class="label">车牌号</text>
      <input
        class="input-field"
        placeholder="请输入车牌号，例如：京A12345"
        value="{{plateNumber}}"
        bindinput="onPlateNumberInput"
        maxlength="8"
      />
    </view>

    <view class="form-item">
      <text class="label">车辆类型</text>
      <picker class="picker" mode="selector" range="{{typeList}}" bindchange="onTypeChange">
        <view class="picker-text">
          {{type || '请选择车辆类型'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">说明</text>
      <view class="picker-text">系统会先创建基础车辆档案，详细 VIN 与发动机信息可后续完善。</view>
    </view>

    <button class="submit-btn glass-btn-cta" bindtap="handleSubmit" disabled="{{!canManageVehicle}}">
      提交
    </button>
  </view>
</view>
