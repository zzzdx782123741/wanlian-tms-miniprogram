<!--pages/driver/vehicles/detail.wxml-->
<view class="detail-container">
  <block wx:if="{{vehicle}}">
    <!-- 车辆头部信息 -->
    <view class="vehicle-header glass-card">
      <text class="plate-number">{{vehicle.plateNumber}}</text>
      <view class="status-badge status-{{vehicle.status}}">
        <text wx:if="{{vehicle.status === 'ACTIVE'}}">运营中</text>
        <text wx:else>闲置</text>
      </view>
    </view>

    <!-- 车辆详细信息 -->
    <view class="info-section glass-card">
      <view class="section-title">车辆信息</view>

      <view class="info-item">
        <text class="label">车型</text>
        <text class="value">{{vehicle.type}}</text>
      </view>

      <view class="info-item">
        <text class="label">载重</text>
        <text class="value">{{vehicle.loadCapacity}}吨</text>
      </view>

      <view class="info-item">
        <text class="label">长度</text>
        <text class="value">{{vehicle.length}}米</text>
      </view>
    </view>

    <!-- 维修记录 -->
    <view class="repair-records-section glass-card">
      <view class="section-title">
        <text>维修记录</text>
        <text class="record-count">({{repairRecords.length}})</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-records" wx:if="{{repairRecords.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无维修记录</text>
      </view>

      <!-- 记录列表 -->
      <view class="record-list" wx:else>
        <view
          class="record-item"
          wx:for="{{repairRecords}}"
          wx:key="_id"
          bindtap="viewOrderDetail"
          data-id="{{item._id}}"
        >
          <view class="record-header">
            <text class="record-type {{item.type === 'maintenance' ? 'type-maintenance' : 'type-repair'}}">
              {{item.typeText}}
            </text>
            <text class="record-status status-{{item.status}}">{{item.statusText}}</text>
          </view>

          <view class="record-body">
            <view class="record-number">订单号：{{item.orderNumber}}</view>
            <view class="record-date">{{item.createdAtText}}</view>

            <view class="record-amount" wx:if="{{item.quote}}">
              <text class="amount-label">金额：</text>
              <text class="amount-value">¥{{item.quote.total / 100}}</text>
            </view>

            <view class="record-fault" wx:if="{{item.faultDescription}}">
              <text class="fault-label">故障：</text>
              <text class="fault-text">{{item.faultDescription}}</text>
            </view>
          </view>

          <view class="record-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button class="action-btn glass-btn" bindtap="editVehicle">编辑</button>
      <button class="action-btn glass-btn-primary" bindtap="applyMaintenance">保养申请</button>
      <button class="action-btn glass-btn-secondary" bindtap="deleteVehicle">删除</button>
    </view>
  </block>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
