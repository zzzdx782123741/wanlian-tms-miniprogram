/* pages/manager/store/store.wxss */
.store-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 30rpx;
}

.section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.edit-btn {
  font-size: 26rpx;
  color: #667eea;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F7FA;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  width: 180rpx;
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-row .value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}

/* 门店照片 */
.photos-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.photos-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.photo-item {
  width: 210rpx;
  height: 210rpx;
  margin: 0 10rpx 20rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo {
  width: 100%;
  height: 100%;
}

.empty-photos {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.action-buttons {
  padding: 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}
