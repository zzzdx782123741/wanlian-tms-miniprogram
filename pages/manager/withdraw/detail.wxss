.detail-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  color: #fff;
  box-shadow: 0 12rpx 28rpx rgba(102, 126, 234, 0.24);
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-amount {
  margin-top: 20rpx;
  font-size: 56rpx;
  font-weight: 700;
}

.hero-no {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.card {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef1f5;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 26rpx;
  color: #888;
}

.value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #222;
  word-break: break-all;
}

.value.strong {
  font-weight: 600;
}

.bank-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.bank-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.proof-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
}

.proof-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f3f5f8;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.cancel-btn {
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #ff7875 0%, #f5222d 100%);
}

.cancel-btn[disabled] {
  opacity: 0.6;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f7fa;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
