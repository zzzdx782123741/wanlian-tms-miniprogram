/* pages/technician/completion/completion.wxss */

page {
  background: #F1F5F9;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 顶部导航 ========== */
.page-header {
  background: #FFFFFF;
  padding: 48rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #E2E8F0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F1F5F9;
  border-radius: 16rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #0F172A;
  font-weight: 300;
}

.page-title {
  font-size: 36rpx;
  color: #0F172A;
  font-weight: 700;
}

/* ========== 筛选标签 ========== */
.filter-tabs {
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.tabs-scroll {
  display: flex;
  white-space: nowrap;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: #F1F5F9;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #64748B;
  font-weight: 600;
  margin-right: 16rpx;
  transition: all 0.2s ease;
  border: 1rpx solid transparent;
}

.tab-item.active {
  background: #2563EB;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.tab-item:last-child {
  margin-right: 0;
}

/* ========== 完工记录列表 ========== */
.record-list {
  flex: 1;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 统计摘要 */
.stats-summary {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #FFFFFF;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
}

/* ========== 记录卡片 ========== */
.record-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 记录头部 */
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.plate-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plate-number {
  font-size: 36rpx;
  color: #0F172A;
  font-weight: 700;
}

.order-type {
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.order-type.type-repair {
  background: #2563EB;
}

.order-type.type-maintenance {
  background: #F59E0B;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #D1FAE5;
  color: #065F46;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid #6EE7B7;
}

.status-icon {
  font-size: 24rpx;
  font-weight: 700;
}

.status-text {
  font-size: 22rpx;
}

/* 完工信息 */
.completion-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #F1F5F9;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 24rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.info-text {
  font-size: 28rpx;
  color: #475569;
  font-weight: 400;
  flex: 1;
}

.info-desc {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 完工图片 */
.completion-images {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.completion-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #F1F5F9;
  border: 1rpx solid #E2E8F0;
}

/* 底部信息 */
.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 8rpx;
}

.footer-text {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.footer-arrow {
  font-size: 32rpx;
  color: #2563EB;
  font-weight: 300;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  color: #64748B;
  font-weight: 600;
}

.empty-desc {
  font-size: 26rpx;
  color: #94A3B8;
  font-weight: 400;
  text-align: center;
}
