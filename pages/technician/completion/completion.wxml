<!--pages/technician/completion/completion.wxml-->
<view class="page">
  <!-- 顶部导航 -->
  <view class="page-header">
    <view class="header-content">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <view class="page-title">完工记录</view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <scroll-view scroll-x class="tabs-scroll" enable-flex>
      <view
        class="tab-item {{activeTab === 'today' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="today"
      >
        今日
      </view>
      <view
        class="tab-item {{activeTab === 'week' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="week"
      >
        本周
      </view>
      <view
        class="tab-item {{activeTab === 'month' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="month"
      >
        本月
      </view>
      <view
        class="tab-item {{activeTab === 'all' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="all"
      >
        全部
      </view>
    </scroll-view>
  </view>

  <!-- 完工记录列表 -->
  <view class="record-list">
    <view class="stats-summary" wx:if="{{records.length > 0}}">
      <view class="stat-item">
        <text class="stat-label">当前筛选</text>
        <text class="stat-value">{{records.length}} 单</text>
      </view>
    </view>

    <view
      class="record-card"
      wx:for="{{records}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="record-header">
        <view class="plate-info">
          <text class="plate-number">{{item.plateNumber}}</text>
          <view class="order-type {{item.type === 'maintenance' ? 'type-maintenance' : 'type-repair'}}">
            {{item.type === 'maintenance' ? '保养' : '维修'}}
          </view>
        </view>
        <view class="status-badge">
          <image class="status-icon svg-icon-sm" src="/images/icons/check-circle.svg" mode="aspectFit" />
          <text class="status-text">已完工</text>
        </view>
      </view>

      <view class="completion-info">
        <view class="info-row">
          <image class="info-icon svg-icon-sm" src="/images/icons/user.svg" mode="aspectFit" />
          <text class="info-text">{{item.driverName}}</text>
        </view>
        <view class="info-row">
          <image class="info-icon svg-icon-sm" src="/images/icons/wrench.svg" mode="aspectFit" />
          <text class="info-text">技师 {{item.technicianName}}</text>
        </view>
        <view class="info-row">
          <image class="info-icon svg-icon-sm" src="/images/icons/check-circle.svg" mode="aspectFit" />
          <text class="info-text">{{item.completedAt}}</text>
        </view>
        <view class="info-row" wx:if="{{item.description}}">
          <image class="info-icon svg-icon-sm" src="/images/icons/note.svg" mode="aspectFit" />
          <text class="info-text info-desc">{{item.description}}</text>
        </view>
      </view>

      <view class="completion-images" wx:if="{{item.images && item.images.length > 0}}">
        <image
          class="completion-image"
          src="{{img}}"
          mode="aspectFill"
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          bindtap="previewImage"
          data-urls="{{item.images}}"
          data-current="{{img}}"
          catch:tap="true"
        ></image>
      </view>

      <view class="record-footer">
        <text class="footer-text">查看详情</text>
        <text class="footer-arrow">→</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{records.length === 0}}">
      <image class="empty-icon svg-icon-xl" src="/images/icons/check-circle.svg" mode="aspectFit" />
      <text class="empty-title">暂无完工记录</text>
      <text class="empty-desc">当前筛选条件下没有找到完工记录</text>
    </view>
  </view>
</view>
