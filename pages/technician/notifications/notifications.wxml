<!--pages/technician/notifications/notifications.wxml-->
<view class="page">
  <!-- 顶部操作栏 -->
  <view class="header-actions">
    <view class="mark-read-btn" bindtap="markAllRead" wx:if="{{hasUnread}}">
      <text class="btn-icon">✓</text>
      <text class="btn-text">全部已读</text>
    </view>
  </view>

  <!-- 通知分类标签 -->
  <view class="filter-tabs">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      全部
      <view class="badge" wx:if="{{totalCount > 0}}">{{totalCount}}</view>
    </view>
    <view class="tab-item {{activeTab === 'order' ? 'active' : ''}}" bindtap="switchTab" data-tab="order">
      订单通知
      <view class="badge" wx:if="{{orderCount > 0}}">{{orderCount}}</view>
    </view>
    <view class="tab-item {{activeTab === 'system' ? 'active' : ''}}" bindtap="switchTab" data-tab="system">
      系统通知
      <view class="badge" wx:if="{{systemCount > 0}}">{{systemCount}}</view>
    </view>
  </view>

  <!-- 通知列表 -->
  <view class="notification-list">
    <view class="notification-item {{item.read ? '' : 'unread'}}"
          wx:for="{{notifications}}"
          wx:key="id"
          bindtap="handleNotification"
          data-item="{{item}}">

      <!-- 通知图标 -->
      <view class="notification-icon {{item.type}}">
        <text class="icon">{{item.icon}}</text>
      </view>

      <!-- 通知内容 -->
      <view class="notification-content">
        <view class="notification-header">
          <text class="notification-title">{{item.title}}</text>
          <text class="notification-time">{{item.time}}</text>
        </view>
        <text class="notification-desc">{{item.description}}</text>
        <view class="notification-meta" wx:if="{{item.orderNumber}}">
          <text class="meta-tag">订单号: {{item.orderNumber}}</text>
        </view>
      </view>

      <!-- 未读标记 -->
      <view class="unread-dot" wx:if="{{!item.read}}"></view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{notifications.length === 0}}">
      <text class="empty-icon">🔔</text>
      <text class="empty-text">暂无通知</text>
    </view>
  </view>
</view>
