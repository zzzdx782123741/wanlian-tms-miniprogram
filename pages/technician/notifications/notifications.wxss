/* pages/technician/notifications/notifications.wxss */

page {
  background: #F5F7FA;
}

.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

/* ========== 顶部操作栏 ========== */
.header-actions {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E4E7;
  display: flex;
  justify-content: flex-end;
}

.mark-read-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #2563EB;
  border-radius: 24rpx;
}

.btn-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 筛选标签 ========== */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #E4E4E7;
}

.tab-item {
  position: relative;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #71717A;
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #2563EB;
  color: #FFFFFF;
}

.tab-item .badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #EF4444;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
  padding: 0 8rpx;
}

/* ========== 通知列表 ========== */
.notification-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.notification-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid #E4E4E7;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.notification-item.unread {
  background: #EFF6FF;
  border-color: #2563EB;
}

.notification-item:active {
  transform: scale(0.98);
}

/* 通知图标 */
.notification-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notification-icon.order {
  background: #DBEAFE;
}

.notification-icon.system {
  background: #FEF3C7;
}

.notification-icon .icon {
  font-size: 40rpx;
}

/* 通知内容 */
.notification-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.notification-title {
  font-size: 30rpx;
  color: #18181B;
  font-weight: 600;
  flex: 1;
}

.notification-time {
  font-size: 24rpx;
  color: #A1A1AA;
  font-weight: 400;
  flex-shrink: 0;
}

.notification-desc {
  font-size: 28rpx;
  color: #71717A;
  font-weight: 400;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 4rpx;
}

.meta-tag {
  padding: 6rpx 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #71717A;
  font-weight: 500;
}

/* 未读标记 */
.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: #EF4444;
  border-radius: 8rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #A1A1AA;
  font-weight: 500;
}
