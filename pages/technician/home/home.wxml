<!--pages/technician/home/home.wxml-->
<view class="page">
  <!-- 主内容区域 -->
  <view class="home-container">
    <!-- 顶部标题栏 -->
    <view class="header">
      <view class="header-left">
        <view class="app-title">
          <text class="title-text">万联驿站</text>
          <text class="version-badge">2.0</text>
        </view>
        <view class="tech-info">技师端 · {{storeName}}</view>
      </view>
      <view class="scan-btn" bindtap="scanCode">
        <text class="scan-icon">🔲</text>
      </view>
    </view>

    <!-- 搜索框 -->
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索车牌号、订单号..."
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
    </view>

    <!-- 统计卡片 -->
    <view class="stats-container">
      <view class="stat-card stat-primary" bindtap="goToCompletionRecords">
        <view class="stat-header">
          <text class="stat-label">今日完工</text>
        </view>
        <view class="stat-value">{{stats.completedToday || 0}}</view>
        <view class="stat-footer" wx:if="{{stats.completedYesterday >= 0}}">
          <text class="stat-trend">较昨日 {{stats.completedToday > stats.completedYesterday ? '+' : ''}}{{stats.completedToday - stats.completedYesterday}}</text>
        </view>
      </view>

      <view class="stat-card stat-secondary">
        <view class="stat-header">
          <text class="stat-label">当前在修</text>
        </view>
        <view class="stat-value">{{stats.inRepair || 0}}</view>
        <view class="stat-footer">
          <text class="stat-status">运行平稳</text>
        </view>
      </view>
    </view>

    <!-- 待办事项 -->
    <view class="section-header">
      <view class="section-title">待办事项</view>
    </view>

    <!-- 订单列表 -->
    <view class="order-list">
      <view class="empty-state" wx:if="{{orderList.length === 0}}">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无待处理订单</text>
      </view>

      <view
        class="order-card"
        wx:for="{{orderList}}"
        wx:key="id"
        bindtap="goToOrderDetail"
        data-id="{{item.id}}"
      >
        <!-- 订单头部 -->
        <view class="order-header">
          <view class="plate-info">
            <text class="plate-number">{{item.plateNumber}}</text>
            <text class="vehicle-model">{{item.vehicleModel}}</text>
          </view>
          <view class="status-badge status-{{item.statusKey}}">
            <text class="status-icon">{{item.statusIcon}}</text>
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>

        <!-- 订单信息 -->
        <view class="order-info">
          <view class="info-row">
            <text class="info-icon">👤</text>
            <text class="info-text">{{item.driverName}} · {{item.driverPhone}}</text>
          </view>
          <view class="info-row">
            <text class="info-icon">⚠️</text>
            <text class="info-text info-desc">{{item.faultDescription}}</text>
          </view>
        </view>

        <!-- 底部信息 -->
        <view class="order-footer">
          <text class="create-time">{{item.createTime}}</text>
          <view class="detail-link">
            <text>查看详情</text>
            <text class="arrow-icon">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view class="tab-item active" bindtap="switchTab" data-tab="home">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">工作台</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-tab="orders">
      <text class="tab-icon">📋</text>
      <text class="tab-label">订单</text>
    </view>
    <view class="tab-item" bindtap="switchTab" data-tab="profile">
      <text class="tab-icon">👤</text>
      <text class="tab-label">我的</text>
    </view>
  </view>
</view>
