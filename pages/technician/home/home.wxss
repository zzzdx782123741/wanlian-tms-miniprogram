/* pages/technician/home/home.wxss */

/* ========== 全局样式 ========== */
page {
  background: #F1F5F9;
  height: 100%;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F1F5F9;
}

/* ========== 主内容区域 ========== */
.home-container {
  flex: 1;
  padding: 0;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ========== 顶部标题栏 ========== */
.header {
  background: #FFFFFF;
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1rpx solid #E2E8F0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.app-title {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.title-text {
  font-size: 48rpx;
  color: #0F172A;
  font-weight: 900;
  letter-spacing: -0.5rpx;
}

.version-badge {
  font-size: 40rpx;
  color: #2563EB;
  font-weight: 900;
}

.tech-info {
  font-size: 22rpx;
  color: #94A3B8;
  font-weight: 500;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.scan-btn {
  width: 80rpx;
  height: 80rpx;
  background: #F1F5F9;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-icon {
  font-size: 40rpx;
}

/* ========== 搜索框 ========== */
.search-box {
  background: #FFFFFF;
  padding: 0 32rpx 24rpx;
  position: relative;
}

.search-icon {
  position: absolute;
  left: 52rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  opacity: 0.4;
}

.search-input {
  width: 100%;
  height: 80rpx;
  background: #F1F5F9;
  border: none;
  border-radius: 24rpx;
  padding: 0 0 0 80rpx;
  font-size: 28rpx;
  color: #0F172A;
  box-sizing: border-box;
}

.search-input::placeholder {
  color: #94A3B8;
}

/* ========== 统计卡片 ========== */
.stats-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx 32rpx;
}

.stat-card {
  padding: 32rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.stat-primary {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
}

.stat-secondary {
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
}

.stat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  opacity: 0.9;
}

.stat-value {
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-footer {
  margin-top: 8rpx;
}

.stat-trend {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.stat-status {
  font-size: 20rpx;
  color: #10B981;
  font-weight: 700;
}

/* ========== 区块标题 ========== */
.section-header {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 900;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ========== 订单列表 ========== */
.order-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.empty-state {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid #E2E8F0;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* ========== 订单卡片 ========== */
.order-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.order-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.plate-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.plate-number {
  font-size: 36rpx;
  color: #0F172A;
  font-weight: 700;
}

.vehicle-model {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 400;
}

/* 状态徽章 */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  border: 1rpx solid;
}

.status-icon {
  font-size: 20rpx;
}

.status-text {
  font-size: 22rpx;
}

/* 不同状态的颜色 */
.status-awaiting_time_confirmation {
  background: #FEF3C7;
  color: #92400E;
  border-color: #FCD34D;
}

.status-pending_assessment {
  background: #DBEAFE;
  color: #1E40AF;
  border-color: #93C5FD;
}

.status-awaiting_approval {
  background: #E9D5FF;
  color: #6B21A8;
  border-color: #C4B5FD;
}

.status-in_repair {
  background: #D1FAE5;
  color: #065F46;
  border-color: #6EE7B7;
}

.status-awaiting_addon_approval {
  background: #FEE2E2;
  color: #991B1B;
  border-color: #FCA5A5;
}

.status-pending_confirmation {
  background: #E0E7FF;
  color: #3730A3;
  border-color: #A5B4FC;
}

/* 订单信息 */
.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 24rpx;
  opacity: 0.6;
}

.info-text {
  font-size: 28rpx;
  color: #475569;
  font-weight: 400;
  flex: 1;
}

.info-desc {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部信息 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F1F5F9;
}

.create-time {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 400;
}

.detail-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.arrow-icon {
  font-size: 32rpx;
  font-weight: 300;
}

/* ========== 底部导航栏 ========== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #E2E8F0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 0.2s ease;
}

.tab-icon {
  font-size: 44rpx;
  opacity: 0.4;
  transition: all 0.2s ease;
}

.tab-label {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-item.active .tab-label {
  color: #2563EB;
}
