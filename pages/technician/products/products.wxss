/* pages/technician/products/products.wxss */
.products-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 30rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  height: 72rpx;
  transition: all 0.3s;
}

.search-box:focus-within {
  background: #fff;
  border: 2rpx solid #667eea;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.clear-icon {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
  margin-left: 8rpx;
}

.scan-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.scan-btn-icon {
  width: 32rpx;
  height: 32rpx;
}

/* ===== 商品分类 ===== */
.category-scroll {
  background: #fff;
  padding: 20rpx 0;
  white-space: nowrap;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-list {
  display: inline-flex;
  padding: 0 30rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.category-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* ===== 商品统计 ===== */
.product-stats {
  background: #fff;
  padding: 16rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-text {
  font-size: 24rpx;
  color: #999;
}

/* ===== 商品列表 ===== */
.product-list {
  padding: 20rpx 30rpx;
}

.product-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* ===== 商品图片 ===== */
.product-image-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.product-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.product-tag {
  position: absolute;
  top: 0;
  left: 0;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  color: #fff;
  font-size: 20rpx;
  border-radius: 12rpx 0 12rpx 0;
}

/* ===== 商品信息 ===== */
.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 180rpx;
}

.product-header {
  margin-bottom: 12rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-brand {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.product-category {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.category-text,
.spec-text {
  color: #666;
}

.divider {
  margin: 0 8rpx;
  color: #ddd;
}

.product-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: auto;
}

/* ===== 商品价格 ===== */
.product-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
  line-height: 1;
  margin: 0 4rpx;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
}

/* ===== 库存信息 ===== */
.stock-info {
  flex-shrink: 0;
}

.stock-text {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.stock-text.in-stock {
  color: #52c41a;
  background: #f6ffed;
}

.stock-text.out-stock {
  color: #ff4d4f;
  background: #fff1f0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}

/* ===== 没有更多 ===== */
.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #bbb;
}

.no-more::before,
.no-more::after {
  content: '';
  width: 60rpx;
  height: 1rpx;
  background: #e8e8e8;
  margin: 0 20rpx;
}
