<!--pages/technician/order-center/order-center.wxml-->
<view class="page">
  <!-- 顶部标题栏 -->
  <view class="page-header">
    <view class="header-content">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <view class="page-title">订单中心</view>
      <view class="scan-btn" bindtap="scanCode">
        <text class="scan-icon">🔲</text>
      </view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      type="text"
      placeholder="搜索车牌号、订单号..."
      value="{{searchQuery}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
  </view>

  <!-- 顶部统计卡片 -->
  <view class="stats-header">
    <view class="stat-card">
      <view class="stat-number">{{stats.todayOrders}}</view>
      <view class="stat-label">今日服务</view>
    </view>
    <view class="stat-card">
      <view class="stat-number">{{stats.weekOrders}}</view>
      <view class="stat-label">本周服务</view>
    </view>
    <view class="stat-card">
      <view class="stat-number">{{stats.monthOrders}}</view>
      <view class="stat-label">本月服务</view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <scroll-view scroll-x class="tabs-scroll" enable-flex>
      <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
      <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待处理</view>
      <view class="tab-item {{activeTab === 'in_repair' ? 'active' : ''}}" bindtap="switchTab" data-tab="in_repair">进行中</view>
      <view class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="plate-info">
          <text class="plate-number">{{item.plateNumber}}</text>
          <view class="order-type {{item.type === 'maintenance' ? 'type-maintenance' : 'type-repair'}}">
            {{item.type === 'maintenance' ? '保养' : '维修'}}
          </view>
        </view>
        <view class="order-status status-{{item.statusClass}}">
          <text class="status-text">{{item.statusText}}</text>
        </view>
      </view>

      <!-- 订单信息 -->
      <view class="order-info">
        <view class="info-row">
          <text class="info-icon">👤</text>
          <text class="info-text">{{item.driverName}}</text>
        </view>
        <view class="info-row" wx:if="{{item.technicianName}}">
          <text class="info-icon">🔧</text>
          <text class="info-text">技师: {{item.technicianName}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">⏰</text>
          <text class="info-text">{{item.appointmentTime}}</text>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <text class="order-number">订单号: {{item.orderNumber}}</text>
        <view class="action-link">
          <text>查看详情</text>
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orders.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无订单</text>
      <text class="empty-desc" wx:if="{{searchQuery}}">未找到匹配的订单</text>
    </view>
  </view>
</view>
