<view class="page">
  <view class="header">
    <view class="header-title">订单中心</view>
    <view class="header-subtitle">统一查看与处理订单</view>
  </view>

  <!-- 搜索框 -->
  <view class="search-container">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索车牌号或订单号"
        value="{{searchQuery}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text class="search-clear" wx:if="{{searchQuery}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <view class="vehicle-filter-chip" wx:if="{{filterVehicleId}}">
    <text class="chip-label">车辆：{{filterVehiclePlate || filterVehicleId}}</text>
    <text class="chip-action" bindtap="onClearVehicleFilter">清除</text>
  </view>

  <view class="filter-tabs {{filterVehicleId ? 'with-chip' : ''}}">
    <view
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}"
      data-tab="all"
      bindtap="onTabChange"
    >
      <text class="tab-text">全部</text>
      <text class="tab-badge" wx:if="{{counts.all > 0}}">{{counts.all}}</text>
    </view>
    <view
      class="tab-item {{activeTab === 'pending' ? 'active' : ''}}"
      data-tab="pending"
      bindtap="onTabChange"
    >
      <text class="tab-text">待处理</text>
      <text class="tab-badge" wx:if="{{counts.pending > 0}}">{{counts.pending}}</text>
    </view>
    <view
      class="tab-item {{activeTab === 'processing' ? 'active' : ''}}"
      data-tab="processing"
      bindtap="onTabChange"
    >
      <text class="tab-text">处理中</text>
      <text class="tab-badge" wx:if="{{counts.processing > 0}}">{{counts.processing}}</text>
    </view>
    <view
      class="tab-item {{activeTab === 'completed' ? 'active' : ''}}"
      data-tab="completed"
      bindtap="onTabChange"
    >
      <text class="tab-text">已完成</text>
      <text class="tab-badge" wx:if="{{counts.completed > 0}}">{{counts.completed}}</text>
    </view>
  </view>

  <view class="order-list">
    <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">{{filterVehicleId ? '该车辆暂无订单' : '暂无订单记录'}}</text>
      <text class="empty-hint">{{filterVehicleId ? '可切换标签查看该车辆的其他订单，或清除筛选' : '当前没有可展示的订单'}}</text>
    </view>

    <view
      class="order-card"
      wx:for="{{orders}}"
      wx:key="_id"
      bindtap="onOrderTap"
      data-id="{{item._id}}"
    >
      <view class="order-header">
        <view class="order-number">订单号：{{item.orderNumber}}</view>
        <view class="order-meta">
          <view class="order-type-badge type-{{item.type}}">
            {{item.type === 'maintenance' ? '保养' : '维修'}}
          </view>
          <view class="order-status status-{{item.status}}">
            {{item.statusText}}
          </view>
        </view>
      </view>

      <view class="order-time">{{item.createdAtText}}</view>

      <view class="order-vehicle">
        <text class="vehicle-icon">🚗</text>
        <view class="vehicle-info">
          <view class="vehicle-plate">{{item.vehicleInfo.plateNumber}}</view>
          <view class="vehicle-model">{{item.vehicleInfo.brand}} {{item.vehicleInfo.model}}</view>
        </view>
      </view>

      <view class="order-fault" wx:if="{{item.type === 'repair' && item.faultDescription}}">
        <text class="fault-label">故障描述：</text>
        <text class="fault-text">{{item.faultDescription}}</text>
      </view>

      <view class="order-maintenance" wx:if="{{item.type === 'maintenance'}}">
        <text class="maint-label">保养类型：</text>
        <text class="maint-value">{{item.maintenanceTypeName || '-'}}</text>
      </view>
      <view class="order-maintenance" wx:if="{{item.type === 'maintenance'}}">
        <text class="maint-label">套餐：</text>
        <text class="maint-value">{{item.packageName || item.selectedTier || '-'}}</text>
      </view>

      <view class="order-progress" wx:if="{{item.showProgress}}">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress}}%"></view>
        </view>
        <view class="progress-text">{{item.progressText}}</view>
      </view>

      <view class="appointment-confirm-section" wx:if="{{role === 'STORE_TECHNICIAN' && item.status === 'awaiting_time_confirmation'}}">
        <view class="confirm-time-hint" catchtap="toggleConfirmTime" data-id="{{item._id}}">
          <view class="hint-content">
            <text class="hint-icon">⏰</text>
            <text class="hint-text">待确认到店时间（点击展开）</text>
            <text class="expand-icon">{{item.showConfirmTime ? '▼' : '▶'}}</text>
          </view>
        </view>

        <view class="confirm-time-form" wx:if="{{item.showConfirmTime}}">
          <view class="driver-preference" wx:if="{{item.appointment}}">
            <view class="preference-label">司机期望时间</view>
            <view class="preference-value">
              <text class="preference-text">{{item.appointment.displayText}}</text>
            </view>
          </view>

          <view class="confirm-actions">
            <button
              class="confirm-btn confirm-action"
              catchtap="onConfirmAppointmentTime"
              data-id="{{item._id}}"
            >
              确认时间
            </button>
            <button
              class="confirm-btn adjust-action"
              catchtap="onOpenTimeAdjuster"
              data-id="{{item._id}}"
            >
              调整时间
            </button>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-price" wx:if="{{item.type === 'repair' && item.quote && item.quote.total}}">
          <text class="price-label">报价：</text>
          <text class="price-value">¥{{item.quote.total}}</text>
        </view>
        <view class="order-price" wx:if="{{item.type === 'maintenance' && item.finalAmount}}">
          <text class="price-label">金额：</text>
          <text class="price-value">¥{{item.finalAmount}}</text>
        </view>

        <button
          class="action-btn-primary"
          wx:if="{{role === 'STORE_TECHNICIAN' && item.status === 'pending_assessment'}}"
          catchtap="onQuoteOrder"
          data-id="{{item._id}}"
        >
          开始检查
        </button>

        <button
          class="action-btn-primary"
          wx:if="{{role === 'STORE_TECHNICIAN' && item.status === 'in_repair'}}"
          catchtap="onCompleteOrder"
          data-id="{{item._id}}"
        >
          提交完工
        </button>

        <button
          class="approve-btn"
          wx:if="{{role !== 'DRIVER' && role !== 'STORE_TECHNICIAN' && item.status === 'awaiting_fleet_approval'}}"
          catchtap="onApproveOrder"
          data-id="{{item._id}}"
        >
          立即审批
        </button>

        <button
          class="approve-btn"
          wx:if="{{role !== 'DRIVER' && role !== 'STORE_TECHNICIAN' && item.status === 'awaiting_approval'}}"
          catchtap="onApproveOrder"
          data-id="{{item._id}}"
        >
          立即审批
        </button>

        <button
          class="approve-btn"
          wx:if="{{role !== 'DRIVER' && role !== 'STORE_TECHNICIAN' && item.status === 'awaiting_addon_approval'}}"
          catchtap="onApproveOrder"
          data-id="{{item._id}}"
        >
          立即审批
        </button>
        <button
          class="confirm-btn"
          wx:if="{{role === 'DRIVER' && ((item.status === 'pending_confirmation') || (item.status === 'completed' && !item.isConfirmed))}}"
          catchtap="onConfirmOrder"
          data-id="{{item._id}}"
        >
          确认完工
        </button>
        <button
          class="review-btn"
          wx:if="{{role === 'DRIVER' && item.canReview}}"
          catchtap="onReviewOrder"
          data-id="{{item._id}}"
        >
          立即评价
        </button>
        <view
          class="order-arrow"
          wx:if="{{!(role !== 'DRIVER' && role !== 'STORE_TECHNICIAN' && (item.status === 'awaiting_fleet_approval' || item.status === 'awaiting_approval')) && !(role === 'DRIVER' && ((item.status === 'pending_confirmation') || (item.status === 'completed' && !item.isConfirmed))) && !(role === 'DRIVER' && item.canReview) && !(role === 'STORE_TECHNICIAN' && (item.status === 'pending_assessment' || item.status === 'in_repair'))}}"
        >›</view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="time-adjuster-mask" wx:if="{{showTimeAdjuster}}" catchtap="onCloseTimeAdjuster">
      <view class="time-adjuster-popup" catchtap="">
        <view class="adjuster-header">
          <text class="adjuster-title">调整到店时间</text>
          <text class="adjuster-close" catchtap="onCloseTimeAdjuster">✕</text>
        </view>

        <view class="selected-time-display" wx:if="{{selectedTimeSlot}}">
          <text class="display-label">已选择：</text>
          <text class="display-value">{{selectedTimeDisplayText}}</text>
        </view>

        <view class="adjuster-content">
          <view class="adjuster-tip">
            <text class="tip-icon">💡</text>
            <text class="tip-text">请选择时间后点击“确定”保存</text>
          </view>

          <view class="time-slots">
            <view
              class="time-slot-item {{selectedTimeSlot === item.time ? 'active' : ''}}"
              wx:for="{{availableTimeSlots}}"
              wx:key="time"
              data-time="{{item.time}}"
              catchtap="onSelectTimeSlot"
            >
              <view class="slot-time">{{item.displayTime}}</view>
              <view class="slot-desc">{{item.description}}</view>
            </view>
          </view>
        </view>

        <view class="adjuster-footer">
          <view class="adjuster-btn cancel-btn" catchtap="onCloseTimeAdjuster">取消</view>
          <view class="adjuster-btn confirm-btn" catchtap="onConfirmAdjustTime">确定</view>
        </view>
      </view>
    </view>
  </view>
</view>
