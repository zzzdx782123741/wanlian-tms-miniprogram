/**
 * 订单列表页面样式 - 现代化设计
 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 60rpx;
  border-radius: 0 0 50% 50% / 0 0 80rpx 80rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ========== 搜索框 ========== */
.search-container {
  background: #fff;
  padding: 24rpx 32rpx;
  margin: -40rpx 32rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-box {
  position: relative;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #F1F5F9;
  border-radius: 20rpx;
  padding: 0 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #0F172A;
  background: transparent;
  border: none;
}

.search-input::placeholder {
  color: #94A3B8;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 18rpx;
  font-size: 22rpx;
  color: #64748B;
  margin-left: 10rpx;
}

/* 车辆筛选提示 */
.vehicle-filter-chip {
  margin: 16rpx 32rpx 0;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  border: 1rpx solid #c7d2fe;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chip-label {
  font-size: 24rpx;
  color: #3730a3;
  font-weight: 600;
}

.chip-action {
  font-size: 24rpx;
  color: #4f46e5;
  font-weight: 700;
  padding: 2rpx 10rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: #fff;
  margin: -40rpx 32rpx 24rpx;
  padding: 12rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
  position: relative;
  z-index: 1;
}

.filter-tabs.with-chip {
  margin-top: 12rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tab-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #718096;
}

.tab-item.active .tab-text {
  color: #fff;
}

.tab-badge {
  margin-left: 8rpx;
  background: rgba(239, 68, 68, 0.15);
  color: #EF4444;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 600;
  min-width: 32rpx;
  text-align: center;
}

.tab-item.active .tab-badge {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

/* 订单列表 */
.order-list {
  padding: 0 32rpx;
}

/* 订单卡片 */
.order-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  padding-top: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.order-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3748;
  flex: 1;
}

/* 订单元信息容器 */
.order-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 订单状态标签 */
.order-status {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 订单类型徽章 */
.order-type-badge {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.type-repair {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  color: #1E40AF;
}

.type-maintenance {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #065F46;
}

.status-pending {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #92400E;
}

.status-received,
.status-quoted,
.status-approved,
.status-completed {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  color: #1E40AF;
}

.status-confirmed {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #065F46;
}

/* 订单时间 */
.order-time {
  font-size: 22rpx;
  color: #A0AEC0;
  margin-bottom: 20rpx;
}

/* 车辆信息 */
.order-vehicle {
  display: flex;
  align-items: center;
  background: #F7FAFC;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.vehicle-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.vehicle-info {
  flex: 1;
}

.vehicle-plate {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 4rpx;
}

.vehicle-model {
  font-size: 24rpx;
  color: #718096;
}

/* 故障描述 */
.order-fault {
  background: #FFFBEB;
  border-left: 4rpx solid #F59E0B;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.fault-label {
  font-size: 24rpx;
  color: #92400E;
  font-weight: 600;
  margin-right: 8rpx;
}

.fault-text {
  font-size: 26rpx;
  color: #78350F;
  line-height: 1.6;
}

/* 保养订单信息 */
.order-maintenance {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F0FDFA;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.maint-label {
  font-size: 24rpx;
  color: #115E59;
  font-weight: 600;
  margin-right: 8rpx;
}

.maint-value {
  font-size: 26rpx;
  color: #134E4A;
}

/* 进度条 */
.order-progress {
  margin: 20rpx 0;
}

.progress-bar {
  height: 8rpx;
  background: #E2E8F0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #667eea;
  text-align: right;
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #E2E8F0;
}

.order-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 24rpx;
  color: #718096;
  margin-right: 8rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.order-arrow {
  font-size: 48rpx;
  color: #CBD5E0;
  font-weight: 300;
}

/* 去审批按钮 */
.approve-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
  margin-left: auto;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.approve-btn::after {
  border: none;
}

/* 去确认按钮 */
.confirm-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
  margin-left: auto;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  animation: pulse 2s infinite;
}

.confirm-btn::after {
  border: none;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.5);
  }
}

/* 去评价按钮 */
.review-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
  margin-left: auto;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.3);
}

.review-btn::after {
  border: none;
}

/* 技师操作按钮 */
.action-btn-primary {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 32rpx;
  border: none;
  margin-left: auto;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.action-btn-primary::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #718096;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #A0AEC0;
}

/* 加载更多 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E2E8F0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #A0AEC0;
}

/* 确认时间模块 */
.appointment-confirm-section {
  margin-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.confirm-time-hint {
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 12rpx;
}

.hint-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hint-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.hint-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
}

.expand-icon {
  font-size: 24rpx;
  color: #92400E;
}

.confirm-time-form {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.driver-preference,
.suggested-time {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: white;
  border-radius: 12rpx;
}

.preference-label,
.suggestion-label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 600;
}

.preference-value,
.suggestion-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.preference-text {
  color: #F59E0B;
}

.confirm-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.confirm-action {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
}

.confirm-action:active {
  opacity: 0.8;
}

.adjust-action {
  background: white;
  color: #F59E0B;
  border: 2rpx solid #F59E0B;
}

.adjust-action:active {
  background: #FFFBEB;
}

/* 时间调整弹窗 */
.time-adjuster-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.time-adjuster-popup {
  width: 100%;
  max-height: 80vh;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.adjuster-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.adjuster-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.adjuster-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.selected-time-display {
  padding: 24rpx 32rpx;
  background: #ECFDF5;
  margin: 24rpx 32rpx 0;
  border-radius: 12rpx;
}

.display-label {
  font-size: 24rpx;
  color: #059669;
  margin-right: 8rpx;
}

.display-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #059669;
}

.adjuster-content {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.adjuster-tip {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #FFFBEB;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #92400E;
}

.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-slot-item {
  padding: 24rpx;
  background: white;
  border: 3rpx solid #e2e8f0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.time-slot-item.active {
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border-color: #10B981;
}

.slot-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.time-slot-item.active .slot-time {
  color: #059669;
}

.slot-desc {
  font-size: 24rpx;
  color: #64748b;
}

.adjuster-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid #f1f5f9;
}

.adjuster-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.cancel-btn:active {
  background: #e2e8f0;
}

.confirm-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
}

.confirm-btn:active {
  opacity: 0.8;
}

