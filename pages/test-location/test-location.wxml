<!--pages/test-location/test-location.wxml-->
<view class="page">
  <view class="header">
    <view class="header-title">
      <image class="header-icon svg-icon-md" src="/images/icons/location-pin.svg" mode="aspectFit" />
      <text>位置功能测试</text>
    </view>
    <view class="header-subtitle">测试腾讯地图 API 和位置服务</view>
  </view>

  <view class="location-card">
    <image class="location-icon svg-icon-xl" src="/images/icons/location-pin.svg" mode="aspectFit" />
    <view class="location-info">
      <view class="location-label">当前位置</view>
      <view class="location-address">{{location.address}}</view>
      <view class="location-coords" wx:if="{{location.latitude}}">
        纬度: {{location.latitude.toFixed(4)}}, 经度: {{location.longitude.toFixed(4)}}
      </view>
    </view>
  </view>

  <view class="test-buttons">
    <button class="test-btn primary" bindtap="testGetLocation">
      <image class="btn-icon svg-icon-sm" src="/images/icons/location-pin.svg" mode="aspectFit" />
      测试获取位置
    </button>
    <button class="test-btn success" bindtap="testChooseLocation">
      <image class="btn-icon svg-icon-sm" src="/images/icons/location-pin.svg" mode="aspectFit" />
      地图选择位置
    </button>
    <button class="test-btn info" bindtap="testDefaultLocation">
      <image class="btn-icon svg-icon-sm" src="/images/icons/building.svg" mode="aspectFit" />
      使用默认地址
    </button>
    <button class="test-btn warning" bindtap="clearResults">
      <image class="btn-icon svg-icon-sm" src="/images/icons/x-circle.svg" mode="aspectFit" />
      清空日志
    </button>
  </view>

  <view class="config-card">
    <view class="config-title">
      <image class="config-title-icon svg-icon-sm" src="/images/icons/settings.svg" mode="aspectFit" />
      <text>配置信息</text>
    </view>
    <view class="config-item">
      <text class="config-label">地图 Key:</text>
      <text class="config-value">{{mapKey}}</text>
    </view>
    <view class="config-item">
      <text class="config-label">功能状态:</text>
      <text class="config-value {{mapEnabled ? 'success' : 'error'}}">
        {{mapEnabled ? '已启用' : '未启用'}}
      </text>
    </view>
  </view>

  <view class="log-card" wx:if="{{testResult.length > 0}}">
    <view class="log-title heading-with-icon">
      <image class="log-title-icon svg-icon-sm" src="/images/icons/clipboard.svg" mode="aspectFit" />
      <text>测试日志</text>
    </view>
    <view class="log-list">
      <view class="log-item" wx:for="{{testResult}}" wx:key="index">
        <view class="log-time">{{item.timestamp}}</view>
        <view class="log-content">
          <view class="log-title">{{item.title}}</view>
          <view class="log-message">{{item.message}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
