<view class="vehicles-container">
  <view class="stats-section">
    <view class="stat-card glass-card">
      <text class="stat-value">{{vehicles.length}}</text>
      <text class="stat-label">总车辆</text>
    </view>
    <view class="stat-card glass-card">
      <text class="stat-value">{{normalCount}}</text>
      <text class="stat-label">正常</text>
    </view>
    <view class="stat-card glass-card">
      <text class="stat-value">{{repairingCount}}</text>
      <text class="stat-label">维修中</text>
    </view>
  </view>

  <view class="action-bar">
    <button class="add-btn glass-btn-cta" bindtap="addVehicle">
      + 新增车辆
    </button>
  </view>

  <view class="vehicles-list">
    <block wx:if="{{vehicles.length > 0}}">
      <view
        class="vehicle-card glass-card"
        wx:for="{{vehicles}}"
        wx:key="_id"
        bindtap="viewDetail"
        data-id="{{item._id}}"
      >
        <view class="vehicle-header">
          <text class="plate-number">{{item.plateNumber}}</text>
          <view class="status-badge status-{{item.status}}">
            <text>{{item.statusText}}</text>
          </view>
        </view>

        <view class="vehicle-info">
          <view class="info-row">
            <text class="label">车辆类型</text>
            <text class="value">{{item.vehicleTypeText}}</text>
          </view>
          <view class="info-row">
            <text class="label">品牌型号</text>
            <text class="value">{{item.brandModelText}}</text>
          </view>
          <view class="info-row">
            <text class="label">当前司机</text>
            <text class="value">{{item.assignedDriverText}}</text>
          </view>
        </view>

        <view class="vehicle-footer">
          <text class="arrow-icon">></text>
        </view>
      </view>
    </block>

    <view wx:else class="empty-state">
      <image class="empty-icon" src="/images/icons/empty-car.png"></image>
      <text class="empty-text">暂无车辆</text>
      <text class="empty-hint">点击上方按钮新增车辆</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
