/**
 * 车队管理员审批订单页面样式
 */

/* 页面容器 */
.approve-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 60rpx;
  border-radius: 0 0 50% 50% / 0 0 80rpx 80rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 订单列表 */
.orders-list {
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

/* 订单卡片 */
.order-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.order-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-right: 80rpx;
}

.order-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D3748;
}

.order-time {
  font-size: 22rpx;
  color: #A0AEC0;
}

/* 车辆信息 */
.vehicle-info {
  display: flex;
  align-items: center;
  background: #F7FAFC;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.vehicle-plate {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3748;
  margin-right: 16rpx;
}

.vehicle-model {
  font-size: 24rpx;
  color: #718096;
}

/* 故障/保养信息 */
.fault-info {
  display: flex;
  align-items: flex-start;
  background: #FFFBEB;
  border-left: 4rpx solid #F59E0B;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.fault-label {
  font-size: 24rpx;
  color: #92400E;
  font-weight: 600;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.fault-text {
  font-size: 26rpx;
  color: #78350F;
  line-height: 1.6;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 我的位置 */
.location-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: #F0F9FF;
  border-radius: 12rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 24rpx;
  color: #0369A1;
  line-height: 1.5;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 司机信息 */
.reporter-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: #F7FAFC;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.reporter-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.reporter-icon {
  font-size: 24rpx;
}

.reporter-label {
  font-size: 24rpx;
  color: #718096;
  font-weight: 600;
}

.reporter-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 32rpx;
}

.reporter-name {
  font-size: 28rpx;
  color: #2D3748;
  font-weight: 600;
}

.reporter-phone {
  font-size: 26rpx;
  color: #667eea;
}

.call-reporter-btn {
  margin-top: 8rpx;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.call-reporter-btn::after {
  border: none;
}

.call-reporter-btn .btn-icon {
  font-size: 22rpx;
}

/* 门店信息 */
.store-info {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.store-info:not(.empty) {
  background: #F0FDF4;
  border: 1rpx solid #86EFAC;
}

.store-info.empty {
  background: #FEF3C7;
  border: 1rpx dashed #FCD34D;
}

.store-label {
  font-size: 24rpx;
  color: #166534;
  margin-right: 8rpx;
}

.store-info.empty .store-label {
  color: #92400E;
}

.store-name {
  font-size: 26rpx;
  color: #166534;
  font-weight: 600;
}

.store-info.empty .store-name {
  color: #92400E;
}

/* 状态标记 */
.status-badge {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.awaiting-fleet-approval {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #92400E;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #718096;
  font-weight: 600;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  font-size: 26rpx;
  color: #A0AEC0;
}
