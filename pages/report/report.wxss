  transition: all 0.2s ease;
  min-width: 180rpx;
  flex-shrink: 0;
}

/* 点击反馈 */
.time-slot::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 40rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.time-slot:active::before {
  opacity: 1;
}

/* 选中状态 */
.time-slot.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
