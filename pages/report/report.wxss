  color: #1F2937;
}

.store-item-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.store-item-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
}

.store-item-distance {
  color: #10B981;
  font-weight: 500;
}

.store-item-location {
  color: #6B7280;
}

.store-item-rating {
  color: #F59E0B;
  font-weight: 500;
}

.store-item-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-item-detail {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.detail-icon {
  font-size: 28rpx;
}

.detail-text {
  flex: 1;
}

.store-item-actions {
  padding: 12rpx 32rpx 12rpx 0;
  display: flex;
  justify-content: flex-end;
}

.store-detail-btn {
  padding: 8rpx 24rpx;
  background: transparent;
  color: #3B82F6;
  border: 1rpx solid #3B82F6;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.store-detail-btn::after {
  border: none;
}

.store-picker-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E5E7EB;
  background: #fff;
}

.store-picker-cancel,
.store-picker-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.store-picker-cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.store-picker-confirm {
  background: #3B82F6;
  color: #fff;
}

.store-picker-confirm[disabled] {
  background: #9CA3AF;
  color: #fff;
}

/* ===== 门店详情弹窗 ===== */
.store-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1001;
  display: flex;
  align-items: flex-end;
}

.store-detail-popup {
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.store-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #E5E7EB;
}

.store-detail-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  padding-right: 16rpx;
}

.store-detail-close {
  font-size: 48rpx;
  color: #9CA3AF;
  line-height: 1;
  flex-shrink: 0;
}

.store-detail-content {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.detail-rating-card {
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.rating-overview {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rating-score {
  font-size: 64rpx;
  font-weight: bold;
  color: #92400E;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 36rpx;
  color: #F59E0B;
}

.rating-count {
  font-size: 24rpx;
  color: #92400E;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-info-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 26rpx;
  color: #4B5563;
}

.info-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.info-text {
  flex: 1;
  line-height: 1.5;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-item {
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.review-author {
  font-size: 26rpx;
  font-weight: 500;
  color: #1F2937;
}

.review-rating {
  display: flex;
  gap: 4rpx;
}

.review-star {
  font-size: 24rpx;
  color: #F59E0B;
}

.review-comment {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.review-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.no-reviews {
  text-align: center;
  padding: 48rpx 24rpx;
}

.no-reviews-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.no-reviews-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #4B5563;
  display: block;
  margin-bottom: 8rpx;
}

.no-reviews-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  display: block;
}

.store-detail-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #E5E7EB;
  background: #fff;
}

.detail-close-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #3B82F6;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

