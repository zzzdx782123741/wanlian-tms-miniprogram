/**
 * 报修申请页面样式 - 优化大字体和易用性
 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 60rpx;
  border-radius: 0 0 50% 50% / 0 0 80rpx 80rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单容器 */
.form-container {
  padding: 0 32rpx;
  margin-top: -40rpx;
}

/* 表单组 */
.form-group {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.form-label {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #EF4444;
  margin-right: 4rpx;
  font-size: 40rpx;
  font-weight: bold;
}

.label-hint {
  font-size: 24rpx;
  font-weight: 400;
  color: #F6AD55;
  margin-left: 8rpx;
}

/* 大卡片选择按钮 */
.big-select-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 160rpx;
  padding: 32rpx;
  background: #F7FAFC;
  border-radius: 24rpx;
  border: 4rpx solid #E2E8F0;
  transition: all 0.3s;
}

.big-select-btn.selected {
  background: #EBF8FF;
  border-color: #4299E1;
}

/* 紧凑选择按钮 */
.compact-select-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  background: #F7FAFC;
  border-radius: 16rpx;
  border: 3rpx solid #E2E8F0;
  transition: all 0.3s;
}

.compact-select-btn:active {
  background: #EBF8FF;
  border-color: #4299E1;
}

.placeholder-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.placeholder-icon-small {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.placeholder-text {
  font-size: 36rpx;
  color: #A0AEC0;
  font-weight: 500;
}

.compact-select-text {
  font-size: 30rpx;
  color: #A0AEC0;
  font-weight: 500;
}

.compact-select-content {
  flex: 1;
}

.compact-select-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
}

.select-content {
  flex: 1;
}

.select-main {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 8rpx;
}

.select-sub {
  font-size: 30rpx;
  color: #718096;
}

.select-arrow {
  font-size: 64rpx;
  color: #CBD5E0;
  font-weight: 300;
  margin-left: 16rpx;
}

.compact-select-arrow {
  font-size: 40rpx;
  color: #CBD5E0;
  font-weight: 300;
}

/* 日期时间选择按钮 - 合并版 */
.datetime-select-btn-full {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 36rpx;
  background: #F7FAFC;
  border-radius: 24rpx;
  border: 4rpx solid #E2E8F0;
  min-height: 180rpx;
  transition: all 0.3s;
}

.datetime-select-btn-full:active {
  background: #EBF8FF;
  border-color: #4299E1;
}

.datetime-select-icon {
  font-size: 72rpx;
  margin-right: 20rpx;
}

.datetime-select-content-full {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.datetime-display-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.datetime-label-small {
  font-size: 28rpx;
  color: #718096;
  min-width: 80rpx;
}

.datetime-value-large {
  font-size: 38rpx;
  color: #2D3748;
  font-weight: 700;
  flex: 1;
}

.datetime-select-arrow {
  font-size: 64rpx;
  color: #CBD5E0;
  font-weight: 300;
  margin-left: 16rpx;
}

/* 日期时间选择器 - 统一按钮 */
.datetime-unified-btn {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #F7FAFC;
  border-radius: 24rpx;
  border: 4rpx solid #E2E8F0;
  min-height: 140rpx;
}

.datetime-unified-btn:active {
  background: #EBF8FF;
  border-color: #4299E1;
}

.datetime-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.datetime-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.datetime-label {
  font-size: 28rpx;
  color: #718096;
}

.datetime-value {
  font-size: 36rpx;
  color: #4299E1;
  font-weight: 700;
}

/* 日期时间选择器 - 紧凑并排按钮 */
.datetime-compact-row {
  display: flex;
  gap: 16rpx;
}

.datetime-compact-picker {
  flex: 1;
}

.datetime-btn {
  flex: 1;
  min-height: 88rpx;
}

/* 故障标签 - 紧凑三行布局 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tags-compact {
  max-height: 180rpx;
  overflow: hidden;
}

.tag-item {
  padding: 16rpx 24rpx;
  background: #F7FAFC;
  border: 3rpx solid #E2E8F0;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #4A5568;
  font-weight: 500;
  transition: all 0.2s;
}

.tag-item.active {
  background: #4299E1;
  border-color: #4299E1;
  color: #fff;
  font-weight: 700;
}

/* ========== 期望到店时间选择器 ========== */
.time-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-option {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  background: #F7FAFC;
  border: 3rpx solid #E2E8F0;
  border-radius: 20rpx;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

/* 点击反馈 */
.time-option::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(102, 126, 234, 0.05);
  opacity: 0;
  transition: opacity 0.2s;
}

.time-option:active::before {
  opacity: 1;
}

/* 选中状态 */
.time-option.active {
  background: linear-gradient(135deg, #EBF4FF 0%, #E6F2FF 100%);
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.time-option-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.time-option-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.time-option-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3748;
  line-height: 1.3;
}

.time-option-desc {
  font-size: 26rpx;
  color: #718096;
  line-height: 1.3;
}

/* 选中状态的文字颜色 */
.time-option.active .time-option-title {
  color: #667eea;
}

.time-option.active .time-option-desc {
  color: #5A67D8;
}

/* 选中标记 */
.time-option.active::after {
  content: '✓';
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 36rpx;
  color: #667eea;
  font-weight: bold;
}

/* 语音输入按钮 */
.voice-input-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.textarea-field::placeholder {
  color: #A0AEC0;
  font-size: 28rpx;
}

.textarea-field-small {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #F7FAFC;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D3748;
  line-height: 1.6;
  box-sizing: border-box;
  border: 3rpx solid #E2E8F0;
}

.textarea-field-small::placeholder {
  color: #A0AEC0;
  font-size: 26rpx;
}

.char-count {
  text-align: right;
  font-size: 26rpx;
  color: #A0AEC0;
  margin-top: 12rpx;
}

/* 输入框 */
.input-field {
  width: 100%;
  padding: 24rpx;
  background: #F7FAFC;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2D3748;
  border: 3rpx solid #E2E8F0;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #A0AEC0;
  font-size: 26rpx;
}

/* 里程输入框区域 */
.mileage-input-row {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.mileage-input-field {
  flex: 1;
  min-width: 0;
  padding: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #1F2937;
  box-sizing: border-box;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
}

.mileage-input-field::placeholder {
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: 400;
}

.mileage-photo-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 160rpx;
  height: 88rpx;
  background: #10B981;
  border-radius: 12rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
  padding: 0 20rpx;
}

.mileage-photo-btn:active {
  background: #059669;
  transform: scale(0.98);
}

.mileage-photo-icon {
  font-size: 32rpx;
  line-height: 1;
}

.mileage-photo-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

.mileage-photos-preview {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.mileage-photo-item {
  width: 180rpx;
  height: 180rpx;
}

/* 媒体上传 */
.media-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.media-upload-btn {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: #F9FAFB;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
  transition: all 0.2s ease;
  gap: 12rpx;
}

.media-upload-btn:active {
  background: #F3F4F6;
  border-color: #9CA3AF;
}

.media-upload-icon {
  font-size: 48rpx;
  color: #9CA3AF;
}

.media-upload-text {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 500;
}

.media-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

/* 媒体网格容器 */
.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 上传按钮卡片 */
.upload-btn-card {
  position: relative;
  width: 216rpx;
  height: 216rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  border: 2rpx dashed #D1D5DB;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.upload-btn-card:active {
  background: #F3F4F6;
  border-color: #9CA3AF;
  transform: scale(0.98);
}

.upload-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 36rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.media-item {
  position: relative;
  width: 216rpx;
  height: 216rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.uploaded-media {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 视频标记 */
.video-badge {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(239, 68, 68, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  z-index: 10;
  transition: all 0.2s ease;
}

.delete-btn:active {
  transform: scale(0.9);
  background: rgba(220, 38, 38, 1);
}

.upload-hint {
  width: 100%;
  font-size: 28rpx;
  color: #F56565;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  border-left: 6rpx solid #F56565;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
  margin-top: 40rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.5);
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 提示信息 */
.tips {
  background: #FFFBEB;
  border-left: 6rpx solid #F59E0B;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 32rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #78350F;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 弹窗遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-popup {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  border-bottom: 2rpx solid #E2E8F0;
}

.picker-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3748;
}

.picker-close {
  font-size: 48rpx;
  color: #718096;
  padding: 8rpx;
}

.picker-list {
  flex: 1;
  max-height: 60vh;
  padding: 16rpx;
  background: #F7FAFC;
}

/* 门店列表特殊背景 */
.store-picker-item .picker-list {
  background: #F7FAFC;
  padding: 16rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 36rpx;
  border-bottom: 2rpx solid #F7FAFC;
  position: relative;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item.active {
  background: #EBF8FF;
}

/* 门店选择弹窗特殊样式 - 覆盖通用样式 */
.store-picker-item {
  display: block !important;
  padding: 0 !important;
  border: none !important;
  margin-bottom: 20rpx;
}

.store-picker-item > view {
  background: #FFFFFF;
  border: 3rpx solid #E2E8F0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.store-picker-item:active > view {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.store-picker-item.active > view {
  background: linear-gradient(135deg, #EBF8FF 0%, #BEE3F8 100%);
  border-color: #4299E1;
  box-shadow: 0 4rpx 16rpx rgba(66, 153, 225, 0.3);
}

.store-picker-item.active {
  background: transparent !important;
}

.store-picker-content {
  width: 100%;
}

.store-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.store-picker-details {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
}

.store-detail-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.store-detail-icon {
  font-size: 28rpx;
  margin-right: 4rpx;
  opacity: 0.8;
}

.store-detail-text {
  font-size: 26rpx;
  color: #4A5568;
  margin-right: 16rpx;
}

.store-detail-text.phone-tap {
  color: #4299E1;
  text-decoration: none;
  font-weight: 600;
  padding: 4rpx 12rpx;
  background: #EBF8FF;
  border-radius: 8rpx;
}

/* 门店特殊样式：覆盖通用picker样式 */
.store-picker-item .picker-item-main {
  font-size: 32rpx !important;
  color: #1A202C !important;
  margin-bottom: 0 !important;
}

.store-picker-item .picker-item-sub {
  font-size: 26rpx !important;
  color: #718096 !important;
  margin-top: 8rpx !important;
  line-height: 1.4 !important;
}

.store-picker-item .picker-check {
  font-size: 40rpx !important;
  margin-left: 12rpx !important;
}

/* 日期时间选择器弹窗 */
.datetime-picker-popup {
  max-height: 80vh;
}

.datetime-section {
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #E2E8F0;
}

.datetime-section:last-child {
  border-bottom: none;
}

.datetime-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 16rpx;
}

.date-picker-large {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: #F7FAFC;
  border-radius: 16rpx;
  border: 3rpx solid #E2E8F0;
}

.date-picker-large-text {
  font-size: 36rpx;
  color: #4299E1;
  font-weight: 600;
}

.date-picker-arrow {
  font-size: 48rpx;
  color: #CBD5E0;
}

/* 日期选择触发器 */
.date-picker-trigger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.date-picker-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #4299E1;
}

.next-step-btn {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
}

.next-step-btn::after {
  border: none;
}

/* 时间选择网格 - 改为单列滚动样式 */
.time-slots-grid {
  height: 600rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.time-slot-item {
  width: 100%;
  padding: 28rpx 32rpx;
  text-align: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 3rpx solid #E2E8F0;
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
  transition: all 0.2s;
  box-sizing: border-box;
}

.time-slot-item.active {
  background: linear-gradient(135deg, #4299E1 0%, #3182CE 100%);
  border-color: #3182CE;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(66, 153, 225, 0.35);
}

/* 媒体上传选择弹窗 */
.media-picker-popup {
  width: 100%;
  background: transparent;
  display: flex;
  align-items: flex-end;
}

