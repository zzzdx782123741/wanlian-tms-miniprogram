/* pages/store/product-select/product-select.wxss - 商品选择页面 */
@import "../../../styles/design-system.wxss";

.product-select-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding-bottom: 40rpx;
}

/* 搜索区域 */
.search-section {
  background: white;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-box {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 80rpx 24rpx 32rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  border-radius: 50rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.search-input:focus {
  background: white;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.search-icon {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
}

/* 分类标签滚动 */
.category-tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-tabs {
  display: flex;
  gap: 16rpx;
}

.category-tab {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: #f5f7fa;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #64748b;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.category-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  border-color: #667eea;
}

/* 商品列表 */
.product-list {
  padding: 24rpx;
}

/* 商品卡片 */
.product-item {
  display: flex;
  background: white;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  position: relative;
}

.product-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s;
}

.product-item:active::before {
  opacity: 1;
}

.product-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

/* 商品图片区域 */
.product-image-wrapper {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
  overflow: hidden;
  border-radius: 24rpx 0 0 24rpx;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  color: white;
  font-size: 22rpx;
  text-align: center;
  padding: 8rpx 0;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.product-image-wrapper:active .image-hint {
  transform: translateY(0);
}

/* 商品信息区域 */
.product-info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.product-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.product-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.4;
  padding-right: 8rpx;
}

.product-category {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 分类颜色 - 优化渐变 */
.category-parts {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
  border: 1rpx solid #93c5fd;
}

.category-labor {
  background: linear-gradient(135deg, #fed7aa 0%, #fdba74 100%);
  color: #9a3412;
  border: 1rpx solid #fb923c;
}

.category-service {
  background: linear-gradient(135deg, #bbf7d0 0%, #86efac 100%);
  color: #166534;
  border: 1rpx solid #4ade80;
}

.category-material {
  background: linear-gradient(135deg, #e9d5ff 0%, #d8b4fe 100%);
  color: #6b21a8;
  border: 1rpx solid #c084fc;
}

/* 规格信息 */
.product-spec {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.spec-item {
  font-size: 24rpx;
  color: #475569;
  background: #f1f5f9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e2e8f0;
}

/* 适配车型 */
.product-models {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
}

.models-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.models-text {
  flex: 1;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
  word-break: break-all;
}

/* 底部信息 */
.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.product-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #dc2626;
  text-shadow: 0 2rpx 4rpx rgba(220, 38, 38, 0.1);
}

.product-unit {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 6rpx;
}

.product-stock {
  font-size: 22rpx;
  color: #64748b;
  background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #cbd5e1;
}

/* 选择按钮 - 优化 */
.select-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.3s;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  border: none;
}

.select-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.5);
  background: linear-gradient(135deg, #5a67d8 0%, #6b46a0 100%);
}

.select-icon {
  font-size: 28rpx;
}

.select-text {
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 24rpx;
  margin: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
  filter: grayscale(0.5);
}

.empty-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.6;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx;
  font-size: 28rpx;
  color: #64748b;
  background: white;
  border-radius: 24rpx;
  margin: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}
