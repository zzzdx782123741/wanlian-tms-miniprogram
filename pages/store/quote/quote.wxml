<!--pages/store/quote/quote.wxml - 门店技师填写报价-->
<wxs module="utils">
  module.exports = {
    toFixed: function(value) {
      return (value || 0).toFixed(2);
    }
  }
</wxs>
<view class="quote-container">
  <block wx:if="{{order}}">
    <!-- 订单信息 -->
    <view class="order-section glass-card">
      <view class="section-title">
        <text class="icon">📋</text>
        <text>订单信息</text>
      </view>

      <view class="info-row">
        <text class="label">订单号</text>
        <text class="value">{{order.orderNumber}}</text>
      </view>

      <view class="info-row">
        <text class="label">车牌号</text>
        <text class="value">{{(order.vehicleId && order.vehicleId.plateNumber) || '-'}}</text>
      </view>

      <view class="info-row">
        <text class="label">车型</text>
        <text class="value">{{(order.vehicleId && order.vehicleId.brand) || '-'}} {{(order.vehicleId && order.vehicleId.model) || ''}}</text>
      </view>

      <view class="info-row">
        <text class="label">预约时间</text>
        <text class="value">{{appointmentConfirmed ? order.appointmentAtText : (order.appointmentAtText || '未预约')}}</text>
      </view>

      <view class="info-row-block">
        <text class="label-block">故障描述</text>
        <text class="value-block fault-desc">{{order.faultDescription}}</text>
      </view>

      <!-- 故障图片 -->
      <block wx:if="{{order.faultImages && order.faultImages.length > 0}}">
        <view class="fault-images">
          <image
            wx:for="{{order.faultImages}}"
            wx:key="*this"
            wx:for-index="imgIndex"
            class="fault-image"
            src="{{item}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-url="{{item}}"
            data-urls="{{order.faultImages}}"
          />
        </view>
      </block>

      <!-- 故障视频 -->
      <block wx:if="{{order.faultVideos && order.faultVideos.length > 0}}">
        <view class="fault-videos">
          <view class="section-subtitle">故障视频</view>
          <view class="video-list">
            <video
              wx:for="{{order.faultVideos}}"
              wx:key="*this"
              wx:for-index="videoIndex"
              class="fault-video"
              src="{{item}}"
              show-center-play-btn="{{true}}"
              controls="{{true}}"
            />
          </view>
        </view>
      </block>

      <!-- 备注信息 -->
      <view class="info-row-block" wx:if="{{order.remark}}">
        <text class="label-block">备注信息</text>
        <text class="value-block">{{order.remark}}</text>
      </view>
    </view>

    <!-- 接车检查 -->
    <view class="form-section glass-card">
      <view class="section-title">
        <text class="icon">🔍</text>
        <text>接车检查</text>
      </view>

      <!-- 当前里程（只读） -->
      <view class="info-row">
        <text class="label">当前里程</text>
        <text class="value">{{order.milestone || '未填写'}} 公里</text>
      </view>

      <!-- 故障诊断 -->
      <view class="form-item">
        <text class="label">故障诊断</text>
        <textarea
          class="textarea-field"
          placeholder="请输入故障诊断结果（选填）"
          value="{{diagnosis}}"
          bindinput="onDiagnosisInput"
          maxlength="500"
        ></textarea>
      </view>

      <!-- 接车照片 -->
      <view class="form-item">
        <text class="label required">接车照片</text>
        <view class="photo-hint">
          <text class="hint-icon">💡</text>
          <text class="hint-text">请拍摄故障位置或更换零件位置作为凭证</text>
        </view>
        <view class="image-upload">
          <block wx:if="{{checkinPhotos.length > 0}}">
            <view class="image-item" wx:for="{{checkinPhotos}}" wx:key="index" wx:for-item="photoItem">
              <image
                class="uploaded-image"
                src="{{photoItem}}"
                mode="aspectFill"
                bindtap="previewImage"
                data-url="{{photoItem}}"
                data-urls="{{checkinPhotos}}"
              />
              <view class="image-delete" bindtap="deleteCheckinPhoto" data-index="{{index}}">
                <text>✕</text>
              </view>
            </view>
          </block>
          <view class="upload-btn" wx:if="{{checkinPhotos.length < 9}}" bindtap="chooseCheckinPhoto">
            <text class="upload-icon">📷</text>
            <text class="upload-text">添加接车照片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 维修项目清单 -->
    <view class="form-section glass-card">
      <view class="section-title">
        <text class="icon">📦</text>
        <text>维修项目清单</text>
      </view>

      <!-- 已选商品列表 -->
      <view class="selected-products" wx:if="{{selectedItems.length > 0}}">
        <view class="product-item" wx:for="{{selectedItems}}" wx:key="*this" wx:for-index="idx">
          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-meta">
              <text class="product-category category-{{item.category}}">{{item.categoryText}}</text>
              <text class="product-divider">|</text>
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-divider">|</text>
              <text class="product-unit">{{item.unit}}</text>
            </view>
          </view>
          <view class="product-actions">
            <view class="quantity-control">
              <view class="quantity-btn minus" bindtap="onDecreaseQuantity" data-index="{{idx}}">-</view>
              <input
                class="quantity-input"
                type="number"
                value="{{item.quantity}}"
                bindinput="onQuantityInput"
                data-index="{{idx}}"
              />
              <view class="quantity-btn plus" bindtap="onIncreaseQuantity" data-index="{{idx}}">+</view>
            </view>
            <view class="item-subtotal">¥{{utils.toFixed(item.price * item.quantity)}}</view>
            <view class="item-delete" bindtap="deleteItem" data-index="{{idx}}">
              <text class="delete-icon">🗑️</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态提示 -->
      <view class="empty-products" wx:if="{{selectedItems.length === 0}}">
        <text class="empty-icon">📦</text>
        <text class="empty-text">还未添加任何项目</text>
        <text class="empty-hint">点击下方按钮从项目库中选择</text>
      </view>

      <!-- 添加商品按钮 -->
      <view class="add-product-btn" bindtap="addProduct">
        <text class="add-icon">➕</text>
        <text>添加维修项目</text>
      </view>

      <!-- 总计区域 -->
      <view class="total-section">
        <view class="total-row">
          <text class="total-label">报价总计</text>
          <text class="total-amount">¥{{totalAmount}}</text>
        </view>
      </view>
    </view>

    <!-- 报价图片 -->
    <view class="form-section glass-card">
      <view class="section-title">
        <text class="icon">📷</text>
        <text>报价图片（选填）</text>
      </view>

      <view class="image-upload">
        <block wx:if="{{quoteImages.length > 0}}">
          <view class="image-item" wx:for="{{quoteImages}}" wx:key="index">
            <image
              class="uploaded-image"
              src="{{item}}"
              mode="aspectFill"
              bindtap="previewImage"
              data-url="{{item}}"
            />
            <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">
              <text>✕</text>
            </view>
          </view>
        </block>

        <view class="upload-btn" wx:if="{{quoteImages.length < 9}}" bindtap="chooseImage">
          <text class="upload-icon">📷</text>
          <text class="upload-text">添加图片</text>
        </view>
      </view>
    </view>

    <!-- 报价说明 -->
    <view class="form-section glass-card">
      <view class="section-title">
        <text class="icon">💬</text>
        <text>报价说明</text>
      </view>

      <textarea
        class="textarea-field"
        placeholder="请输入报价说明、维修方案、预计完成时间等（选填）"
        value="{{description}}"
        bindinput="onDescriptionInput"
        maxlength="500"
      ></textarea>
    </view>

    <!-- 审批流程提示 -->
    <view class="process-hint">
      <view class="hint-title">📢 审批流程</view>
      <view class="hint-steps">
        <view class="hint-step">
          <view class="step-number">1</view>
          <view class="step-text">提交报价</view>
        </view>
        <view class="step-arrow">→</view>
        <view class="hint-step">
          <view class="step-number">2</view>
          <view class="step-text">车队审批</view>
        </view>
        <view class="step-arrow">→</view>
        <view class="hint-step">
          <view class="step-number">3</view>
          <view class="step-text">开始维修</view>
        </view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn glass-btn-cta"
      bindtap="handleSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交报价'}}
    </button>
  </block>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>
</view>
