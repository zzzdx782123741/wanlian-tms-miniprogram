/* pages/store/orders/orders.wxss - 门店技师接单大厅 */
@import "../../../styles/design-system.wxss";

.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx;
  color: white;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 标签切换 */
.tabs-container {
  display: flex;
  background: white;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #64748b;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #667eea;
  font-weight: bold;
  background: rgba(102, 126, 234, 0.05);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

/* 订单容器 */
.orders-container {
  padding: 24rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* 订单卡片 */
.order-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.order-card:active {
  transform: scale(0.98);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.order-number {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
  font-family: 'Courier New', monospace;
  flex: 1;
  padding-right: 16rpx;
}

.order-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 订单元信息 */
.order-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.order-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.order-debug {
  font-size: 20rpx;
  color: #cbd5e1;
  font-family: monospace;
}

.status-warning {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.status-info {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
}

.status-primary {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4338ca;
}

.status-success {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
}

.status-error {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #991b1b;
}

/* 订单区块 */
.order-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  font-weight: 600;
}

/* 车辆信息 */
.vehicle-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vehicle-plate {
  font-size: 36rpx;
  font-weight: bold;
  color: #1e293b;
  letter-spacing: 2rpx;
}

.vehicle-model {
  font-size: 28rpx;
  color: #64748b;
}

/* 故障描述 */
.fault-description {
  font-size: 30rpx;
  color: #334155;
  line-height: 1.8;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
}

.fault-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.fault-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #64748b;
}

.info-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 24rpx;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.action-hint {
  padding: 16rpx 20rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  color: #92400E;
  font-size: 28rpx;
  text-align: center;
  border: 2rpx solid #F59E0B;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
}

.action-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
}

.action-btn-primary:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.action-btn-warning {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: white;
  box-shadow: 0 8rpx 16rpx rgba(245, 158, 11, 0.3);
}

.action-btn-warning:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.action-btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
}

.action-btn-secondary:active {
  background: #e2e8f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #64748b;
}

/* 确认时间模块 */
.appointment-confirm-section {
  margin-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.confirm-time-hint {
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 12rpx;
}

.hint-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hint-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.hint-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
}

.expand-icon {
  font-size: 24rpx;
  color: #92400E;
}

.confirm-time-form {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.driver-preference,
.suggested-time {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: white;
  border-radius: 12rpx;
}

.preference-label,
.suggestion-label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 600;
}

.preference-value,
.suggestion-value {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
}

.preference-text {
  color: #F59E0B;
}

.confirm-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.confirm-action {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
}

.confirm-action:active {
  opacity: 0.8;
}

.adjust-action {
  background: white;
  color: #F59E0B;
  border: 2rpx solid #F59E0B;
}

.adjust-action:active {
  background: #FFFBEB;
}

/* 时间调整弹窗 */
.time-adjuster-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
}

.time-adjuster-popup {
  width: 100%;
  height: calc(100vh - 96rpx);
  max-height: calc(100vh - 96rpx);
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.adjuster-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.adjuster-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}

.adjuster-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.selected-time-display {
  padding: 24rpx 32rpx;
  background: #ECFDF5;
  margin: 24rpx 32rpx 0;
  border-radius: 12rpx;
}

.display-label {
  font-size: 24rpx;
  color: #059669;
  margin-right: 8rpx;
}

.display-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #059669;
}

.adjuster-content {
  flex: 1;
  height: 0;
  padding: 24rpx 32rpx;
  min-height: 0;
  box-sizing: border-box;
}

.adjuster-tip {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #FFFBEB;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #92400E;
}

.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-slot-item {
  padding: 24rpx;
  background: white;
  border: 3rpx solid #e2e8f0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.time-slot-item.active {
  background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
  border-color: #10B981;
}

.slot-time {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.time-slot-item.active .slot-time {
  color: #059669;
}

.slot-desc {
  font-size: 24rpx;
  color: #64748b;
}

.adjuster-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f1f5f9;
  background: #fff;
}

.adjuster-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.cancel-btn {
  background: #f1f5f9;
  color: #64748b;
}

.cancel-btn:active {
  background: #e2e8f0;
}

.adjuster-footer .confirm-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: white;
}

.adjuster-footer .confirm-btn:active {
  opacity: 0.8;
}
