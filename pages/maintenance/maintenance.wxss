/* pages/maintenance/maintenance.wxss - 保养申请页面样式 */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 顶部标题栏 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 32rpx;
  color: white;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 内容滚动区 */
.content {
  flex: 1;
  padding: 24rpx 24rpx 160rpx;
}

/* 卡片通用样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title-tip {
  font-size: 24rpx;
  font-weight: normal;
  color: #909399;
}

/* 车辆信息 */
.vehicle-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plate-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.vehicle-model {
  font-size: 28rpx;
  color: #606266;
}

.mileage {
  font-size: 28rpx;
  color: #409eff;
  font-weight: 500;
}

/* 我的位置 */
.location-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.location-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.location-content {
  flex: 1;
  min-width: 0;
}

.location-address {
  font-size: 30rpx;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-tip {
  font-size: 24rpx;
  color: #909399;
}

.location-change-btn {
  padding: 12rpx 24rpx;
  background-color: #f0f9ff;
  color: #409eff;
  border: 1rpx solid #b3d8ff;
  border-radius: 8rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.location-change-btn::after {
  border: none;
}

.location-change-icon {
  font-size: 28rpx;
}

/* 保养类型列表 */
.type-list {
  white-space: nowrap;
}

.type-item {
  display: inline-block;
  width: 240rpx;
  padding: 24rpx;
  margin-right: 16rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  vertical-align: top;
  transition: all 0.3s;
}

.type-item.active {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.type-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.type-desc {
  display: block;
  font-size: 24rpx;
  color: #909399;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 套餐列表 */
.packages-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.package-item {
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.package-item.active {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.package-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.package-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  flex: 1;
}

.package-tier {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.tier-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  color: white;
}

.tier-tag[data-tier="basic"] {
  background-color: #909399;
}

.tier-tag[data-tier="standard"] {
  background-color: #409eff;
}

.tier-tag[data-tier="premium"] {
  background-color: #67c23a;
}

.tier-tag[data-tier="luxury"] {
  background-color: #e6a23c;
}

.package-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #f56c6c;
}

.package-products {
  font-size: 24rpx;
  color: #909399;
}

.package-desc {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
  padding-top: 12rpx;
  border-top: 1rpx solid #dcdfe6;
}

/* 档位列表 */
.tier-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tier-item {
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s;
}

.tier-item.active {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.tier-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.tier-desc {
  font-size: 26rpx;
  color: #909399;
}

/* 商品列表 */
.products-tip {
  font-size: 24rpx;
  color: #409eff;
  margin-left: auto;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.product-item.checked {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.product-checkbox {
  margin-right: 16rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.product-spec {
  font-size: 24rpx;
  color: #909399;
}

.product-price {
  font-size: 28rpx;
  color: #f56c6c;
  font-weight: 500;
}

/* 时间偏好 */
.time-preference {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-label {
  font-size: 28rpx;
  color: #606266;
}

.time-value {
  font-size: 28rpx;
  color: #409eff;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-change {
  padding: 8rpx 16rpx;
  background-color: #f0f9ff;
  color: #409eff;
  border-radius: 4rpx;
  font-size: 24rpx;
}

/* 备注输入 */
.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: white;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 选择器遮罩 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

/* 选择器弹窗 */
.picker-popup {
  width: 100%;
  max-height: 80vh;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #ebeef5;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.picker-close {
  font-size: 44rpx;
  color: #909399;
  padding: 8rpx;
}

/* 不限时间选项 */
.time-unlimited-option {
  padding: 32rpx;
  border-bottom: 1rpx solid #ebeef5;
}

.option-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.option-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #909399;
}

/* 日期选择区 */
.date-section {
  padding: 32rpx;
}

.date-picker {
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  text-align: center;
}

.date-picker-text {
  font-size: 28rpx;
  color: #409eff;
}

/* 时间选择区 */
.time-section {
  margin-top: 24rpx;
}

.time-slots {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  max-height: 400rpx;
}

.time-slot-item {
  padding: 16rpx;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #606266;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.time-slot-item:active {
  background-color: #ecf5ff;
  border-color: #409eff;
  color: #409eff;
}

/* 地址选择弹窗 */
.location-picker-popup {
  width: 90%;
  margin: 0 auto;
  border-radius: 16rpx;
  overflow: hidden;
}

.location-option {
  width: 100%;
  padding: 32rpx;
  background-color: white;
  border: none;
  border-bottom: 1rpx solid #ebeef5;
  display: flex;
  align-items: center;
  gap: 24rpx;
  text-align: left;
}

.location-option::after {
  border: none;
}

/* 加载状态 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top-color: #409eff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #606266;
}

/* 语音输入提示 */
.voice-input-hint {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #FFF9E6;
  border-left: 4rpx solid #E6A23C;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #606266;
}

/* 车队提示卡片 */
.fleet-tip-card {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #F0F9FF;
  border-left: 4rpx solid #409EFF;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.tip-text {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.6;
}

/* 必填标记 */
.required {
  color: #f56c6c;
  margin-left: 4rpx;
  font-size: 28rpx;
}

/* 里程输入 */
.mileage-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
}

.mileage-input {
  flex: 1;
  font-size: 32rpx;
  color: #1a1a1a;
}

.mileage-unit {
  font-size: 28rpx;
  color: #909399;
}

/* 里程照片 */
.milestone-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  line-height: 1;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #dcdfe6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background-color: #fafafa;
}

.photo-add-icon {
  font-size: 48rpx;
  color: #909399;
  line-height: 1;
}

.photo-add-text {
  font-size: 24rpx;
  color: #909399;
}

.photos-tip {
  font-size: 24rpx;
  color: #909399;
  text-align: center;
}

/* ==================== 门店选择样式 ==================== */
.store-select-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  min-height: 88rpx;
}

.store-select-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.store-select-value {
  font-size: 32rpx;
  color: #303133;
  font-weight: 500;
}

.store-distance {
  font-size: 24rpx;
  color: #67c23a;
  background-color: #f0f9ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.store-select-placeholder {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.placeholder-icon {
  font-size: 36rpx;
}

.store-select-text {
  font-size: 28rpx;
  color: #909399;
}

.store-select-arrow {
  font-size: 48rpx;
  color: #c0c4cc;
  font-weight: 300;
}

/* 门店选择器弹窗 */
.store-picker-popup {
  width: 560rpx;
  max-height: 80vh;
  background-color: white;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.store-list {
  flex: 1;
  max-height: 500rpx;
  padding: 16rpx 0;
}

.store-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #ebeef5;
  transition: background-color 0.2s;
}

.store-item:active {
  background-color: #f5f7fa;
}

.store-item.active {
  background-color: #ecf5ff;
}

.store-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-item-name {
  font-size: 32rpx;
  color: #303133;
  font-weight: 500;
}

.store-item-address {
  font-size: 24rpx;
  color: #909399;
}

.store-item-distance {
  font-size: 24rpx;
  color: #67c23a;
}

.store-item-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #409eff;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.store-picker-footer {
  display: flex;
  border-top: 1rpx solid #ebeef5;
  padding: 16rpx 32rpx;
  gap: 16rpx;
}

.store-picker-cancel,
.store-picker-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.store-picker-cancel {
  background-color: #f5f7fa;
  color: #606266;
}

.store-picker-confirm {
  background-color: #409eff;
  color: white;
}

/* 门店详情弹窗 */
.store-detail-popup {
  width: 560rpx;
  max-height: 80vh;
  background-color: white;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.store-detail-content {
  flex: 1;
  max-height: 600rpx;
  padding: 32rpx;
}

.store-detail-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}

.store-detail-address {
  font-size: 28rpx;
  color: #606266;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.store-detail-phone {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #606266;
  padding: 16rpx 0;
  border-top: 1rpx solid #ebeef5;
  margin-bottom: 24rpx;
}

.store-call-btn {
  color: #409eff;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  background-color: #ecf5ff;
}

.store-reviews {
  margin-top: 24rpx;
}

.reviews-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #303133;
  margin-bottom: 16rpx;
}

.review-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.reviewer-name {
  font-size: 26rpx;
  color: #606266;
}

.review-rating {
  font-size: 24rpx;
  color: #f7ba2a;
}

.review-comment {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.5;
}

/* ==================== 新增：分类套餐样式 ==================== */

/* 智能推荐区 */
.top-recommendations {
  margin-top: 16rpx;
}

.recommendations-scroll {
  white-space: nowrap;
}

.recommendation-card {
  display: inline-block;
  width: 280rpx;
  padding: 24rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #fff 100%);
  border: 2rpx solid #ffd666;
  border-radius: 16rpx;
  vertical-align: top;
  position: relative;
}

.recommendation-card.active {
  border-color: #409eff;
  background: linear-gradient(135deg, #e6f7ff 0%, #fff 100%);
}

.rec-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  color: white;
  font-size: 20rpx;
  border-radius: 12rpx;
}

.rec-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin: 8rpx 0;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.rec-tier {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #ecf5ff;
  color: #409eff;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.rec-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rec-products {
  font-size: 22rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 分类套餐区域 */
.category-section {
  border-bottom: 1rpx solid #ebeef5;
}

.category-section:last-child {
  border-bottom: none;
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  cursor: pointer;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
}

.category-count {
  font-size: 24rpx;
  color: #909399;
  margin-left: 8rpx;
}

.category-arrow {
  font-size: 24rpx;
  color: #909399;
  transition: transform 0.3s;
}

.category-arrow.expanded {
  transform: rotate(180deg);
}

.category-packages {
  padding-bottom: 16rpx;
}

/* 套餐行样式 */
.package-row {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.package-row.selected {
  background-color: #ecf5ff;
  border-color: #409eff;
}

.package-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.package-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.package-tier-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #409eff;
  color: white;
  font-size: 22rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.package-row-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #303133;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.package-right {
  flex-shrink: 0;
}

.package-row-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.package-detail-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx;
  background-color: rgba(64, 158, 255, 0.1);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #409eff;
}

.toggle-arrow {
  font-size: 20rpx;
  transition: transform 0.3s;
}

.toggle-arrow.up {
  transform: rotate(180deg);
}

/* 商品明细列表 */
.package-products-list {
  padding: 16rpx;
  margin-top: 12rpx;
  background-color: white;
  border-radius: 8rpx;
}

.product-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-row:last-child {
  border-bottom: none;
}

.product-dot {
  color: #409eff;
  margin-right: 8rpx;
}

.product-name {
  flex: 1;
  font-size: 26rpx;
  color: #606266;
}

.product-qty {
  font-size: 24rpx;
  color: #909399;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #909399;
}
