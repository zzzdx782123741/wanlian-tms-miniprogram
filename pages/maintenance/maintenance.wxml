<!--pages/maintenance/maintenance.wxml - 保养申请页面-->
<view class="page">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-title">保养申请</view>
    <view class="header-subtitle">选择保养类型和套餐</view>
  </view>

  <scroll-view class="content" scroll-y>
    <!-- 车辆信息 -->
    <view class="card">
      <view class="card-title">车辆信息</view>
      <view class="vehicle-info">
        <text class="plate-number">{{vehicle.plateNumber}}</text>
        <text class="vehicle-model">{{vehicle.brand}} {{vehicle.model}}</text>
        <view class="mileage">当前里程：{{vehicle.mileage}} km</view>
      </view>
    </view>

    <!-- 车辆位置 -->
    <view class="card">
      <view class="card-title">车辆位置</view>
      <view class="location-info">
        <text class="location-icon">📍</text>
        <view class="location-content">
          <view class="location-address">{{serviceLocation.address}}</view>
          <view class="location-tip">点击修改车辆位置</view>
        </view>
        <button class="location-change-btn" catchtap="onChangeLocation">
          <text class="location-change-icon">📍</text>
          <text>修改地址</text>
        </button>
      </view>
    </view>

    <!-- 当前里程（必填） -->
    <view class="card">
      <view class="card-title">
        <text>当前里程</text>
        <text class="required">*</text>
      </view>
      <view class="mileage-input-wrapper">
        <input
          class="mileage-input"
          type="digit"
          placeholder="请输入当前里程"
          value="{{milestone}}"
          bindinput="onMilestoneInput"
        />
        <text class="mileage-unit">km</text>
      </view>
    </view>

    <!-- 选择保养门店（必填） -->
    <view class="card">
      <view class="card-title">
        <text>选择保养门店</text>
        <text class="required">*</text>
        <text class="title-tip">（选择门店后可查看该门店的套餐）</text>
      </view>
      <view class="store-select-btn" bindtap="openStorePicker">
        <view class="store-select-content" wx:if="{{selectedStoreIndex !== -1}}">
          <text class="store-select-value">{{stores[selectedStoreIndex].label}}</text>
          <text class="store-distance" wx:if="{{stores[selectedStoreIndex].distance}}">
            {{stores[selectedStoreIndex].distance}}km
          </text>
        </view>
        <view class="store-select-placeholder" wx:else>
          <text class="placeholder-icon">🔧</text>
          <text class="store-select-text">点击选择门店</text>
        </view>
        <text class="store-select-arrow">›</text>
      </view>
    </view>

    <!-- 里程照片（必填，1-3张） -->
    <view class="card">
      <view class="card-title">
        <text>里程照片</text>
        <text class="required">*</text>
        <text class="title-tip">（请拍摄仪表盘里程照片，1-3张）</text>
      </view>
      <view class="milestone-photos">
        <view class="photo-item" wx:for="{{milestonePhotos}}" wx:key="*this">
          <image class="photo-image" src="{{item}}" mode="aspectFill" bindtap="onPreviewPhoto" data-url="{{item}}" />
          <view class="photo-delete" catchtap="onDeletePhoto" data-index="{{index}}">✕</view>
        </view>
        <view class="photo-add" wx:if="{{milestonePhotos.length < 3}}" bindtap="onAddMilestonePhoto">
          <text class="photo-add-icon">+</text>
          <text class="photo-add-text">添加照片</text>
        </view>
      </view>
      <view class="photos-tip">已上传 {{milestonePhotos.length}}/3 张</view>
    </view>

    <!-- 保养类型 -->
    <view class="card" wx:if="{{maintenanceTypes.length > 0}}">
      <view class="card-title">选择保养类型</view>
      <scroll-view class="type-list" scroll-x>
        <view
          class="type-item {{selectedTypeIndex === index ? 'active' : ''}}"
          wx:for="{{maintenanceTypes}}"
          wx:key="*this"
          data-index="{{index}}"
          bindtap="onSelectType"
        >
          <text class="type-icon">{{item.icon}}</text>
          <text class="type-name">{{item.name}}</text>
          <text class="type-desc">{{item.description}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 智能推荐套餐（基于里程） - 必须先选择门店 -->
    <view class="card" wx:if="{{selectedStoreIndex !== -1 && topRecommendations.length > 0}}">
      <view class="card-title">
        <text class="title-icon">🔥</text>
        <text>智能推荐</text>
        <text class="title-tip">（基于当前里程 {{milestone || vehicle.mileage}}km）</text>
      </view>

      <view class="top-recommendations">
        <scroll-view class="recommendations-scroll" scroll-x>
          <view
            class="recommendation-card {{selectedPackageId === item._id ? 'active' : ''}}"
            wx:for="{{topRecommendations}}"
            wx:key="_id"
            data-category="{{item.category}}"
            data-index="{{index}}"
            bindtap="onSelectPackage"
          >
            <view class="rec-badge">{{item.recommendationReason || '智能推荐'}}</view>
            <view class="rec-name">{{item.name}}</view>
            <view class="rec-tier">{{item.tierName || item.tier}}</view>
            <view class="rec-price">¥{{item.price}}</view>
            <view class="rec-products">含 {{item.products.length}} 项商品</view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 全部套餐分类 - 必须先选择门店 -->
    <view class="card" wx:if="{{selectedStoreIndex !== -1 && (categorizedPackages.minor.packages.length > 0 || categorizedPackages.major.packages.length > 0 || categorizedPackages.special.packages.length > 0)}}">
      <view class="card-title">
        <text>全部套餐</text>
        <text class="title-tip">（按分类选择）</text>
      </view>

      <!-- 小保养分类 -->
      <view class="category-section" wx:if="{{categorizedPackages.minor.packages.length > 0}}">
        <view class="category-header" data-category="minor" bindtap="onToggleCategory">
          <view class="category-info">
            <text class="category-icon">🛢️</text>
            <text class="category-name">小保养</text>
            <text class="category-count">{{categorizedPackages.minor.packages.length}} 个套餐</text>
          </view>
          <text class="category-arrow {{categorizedPackages.minor.expanded ? 'expanded' : ''}}">▼</text>
        </view>

        <view class="category-packages" wx:if="{{categorizedPackages.minor.expanded}}">
          <view
            class="package-row {{selectedPackageId === item._id ? 'selected' : ''}}"
            wx:for="{{categorizedPackages.minor.packages}}"
            wx:key="_id"
            wx:for-item="pkg"
            wx:for-index="pkgIndex"
            data-category="minor"
            data-index="{{pkgIndex}}"
            bindtap="onSelectPackage"
          >
            <view class="package-main">
              <view class="package-left">
                <text class="package-tier-tag">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-row-name">{{pkg.name}}</text>
              </view>
              <view class="package-right">
                <text class="package-row-price">¥{{pkg.price}}</text>
              </view>
            </view>
            <view class="package-detail-toggle" data-category="minor" data-index="{{pkgIndex}}" catchtap="onTogglePackageDetail">
              <text>商品明细</text>
              <text class="toggle-arrow {{pkg.expanded ? 'up' : ''}}">▼</text>
            </view>
            <view class="package-products-list" wx:if="{{pkg.expanded}}">
              <view class="product-row" wx:for="{{pkg.products}}" wx:key="productId" wx:for-item="product">
                <text class="product-dot">•</text>
                <text class="product-name">{{product.productId.name || product.name}}</text>
                <text class="product-qty">x{{product.quantity || 1}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 大保养分类 -->
      <view class="category-section" wx:if="{{categorizedPackages.major.packages.length > 0}}">
        <view class="category-header" data-category="major" bindtap="onToggleCategory">
          <view class="category-info">
            <text class="category-icon">🔧</text>
            <text class="category-name">大保养</text>
            <text class="category-count">{{categorizedPackages.major.packages.length}} 个套餐</text>
          </view>
          <text class="category-arrow {{categorizedPackages.major.expanded ? 'expanded' : ''}}">▼</text>
        </view>

        <view class="category-packages" wx:if="{{categorizedPackages.major.expanded}}">
          <view
            class="package-row {{selectedPackageId === item._id ? 'selected' : ''}}"
            wx:for="{{categorizedPackages.major.packages}}"
            wx:key="_id"
            wx:for-item="pkg"
            wx:for-index="pkgIndex"
            data-category="major"
            data-index="{{pkgIndex}}"
            bindtap="onSelectPackage"
          >
            <view class="package-main">
              <view class="package-left">
                <text class="package-tier-tag">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-row-name">{{pkg.name}}</text>
              </view>
              <view class="package-right">
                <text class="package-row-price">¥{{pkg.price}}</text>
              </view>
            </view>
            <view class="package-detail-toggle" data-category="major" data-index="{{pkgIndex}}" catchtap="onTogglePackageDetail">
              <text>商品明细</text>
              <text class="toggle-arrow {{pkg.expanded ? 'up' : ''}}">▼</text>
            </view>
            <view class="package-products-list" wx:if="{{pkg.expanded}}">
              <view class="product-row" wx:for="{{pkg.products}}" wx:key="productId" wx:for-item="product">
                <text class="product-dot">•</text>
                <text class="product-name">{{product.productId.name || product.name}}</text>
                <text class="product-qty">x{{product.quantity || 1}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 专项保养分类 -->
      <view class="category-section" wx:if="{{categorizedPackages.special.packages.length > 0}}">
        <view class="category-header" data-category="special" bindtap="onToggleCategory">
          <view class="category-info">
            <text class="category-icon">⚙️</text>
            <text class="category-name">专项保养</text>
            <text class="category-count">{{categorizedPackages.special.packages.length}} 个套餐</text>
          </view>
          <text class="category-arrow {{categorizedPackages.special.expanded ? 'expanded' : ''}}">▼</text>
        </view>

        <view class="category-packages" wx:if="{{categorizedPackages.special.expanded}}">
          <view
            class="package-row {{selectedPackageId === item._id ? 'selected' : ''}}"
            wx:for="{{categorizedPackages.special.packages}}"
            wx:key="_id"
            wx:for-item="pkg"
            wx:for-index="pkgIndex"
            data-category="special"
            data-index="{{pkgIndex}}"
            bindtap="onSelectPackage"
          >
            <view class="package-main">
              <view class="package-left">
                <text class="package-tier-tag">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-row-name">{{pkg.name}}</text>
              </view>
              <view class="package-right">
                <text class="package-row-price">¥{{pkg.price}}</text>
              </view>
            </view>
            <view class="package-detail-toggle" data-category="special" data-index="{{pkgIndex}}" catchtap="onTogglePackageDetail">
              <text>商品明细</text>
              <text class="toggle-arrow {{pkg.expanded ? 'up' : ''}}">▼</text>
            </view>
            <view class="package-products-list" wx:if="{{pkg.expanded}}">
              <view class="product-row" wx:for="{{pkg.products}}" wx:key="productId" wx:for-item="product">
                <text class="product-dot">•</text>
                <text class="product-name">{{product.productId.name || product.name}}</text>
                <text class="product-qty">x{{product.quantity || 1}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态提示 -->
    <view class="card" wx:if="{{selectedStoreIndex === -1 || (topRecommendations.length === 0 && categorizedPackages.minor.packages.length === 0 && categorizedPackages.major.packages.length === 0 && categorizedPackages.special.packages.length === 0)}}">
      <view class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">请先选择门店后查看套餐</text>
      </view>
    </view>

    <!-- 自定义商品（司机有权限时） -->
    <view class="card" wx:if="{{fleetConfig.maintenanceProductPermission === 'driver_select' && allProducts.length > 0}}">
      <view class="card-title">
        <text>选择商品（可多选）</text>
        <view class="products-tip">已选 {{selectedProductIndices.length}} 项，总价 ¥{{calculateProductsPrice()}}</view>
      </view>

      <checkbox-group>
        <label
          class="product-item {{selectedProductIndices.indexOf(index) > -1 ? 'checked' : ''}}"
          wx:for="{{allProducts}}"
          wx:key="*this"
          data-index="{{index}}"
          bindtap="onToggleProduct"
        >
          <view class="product-checkbox">
            <checkbox value="{{index}}" checked="{{selectedProductIndices.indexOf(index) > -1}}" />
          </view>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-spec">{{item.spec}}</text>
            <text class="product-price">¥{{item.price}}</text>
          </view>
        </label>
      </checkbox-group>
    </view>

    <!-- 到店时间偏好 -->
    <view class="card">
      <view class="card-title">到店时间偏好</view>
      <view class="time-preference">
        <text class="time-label">期望到店时间：</text>
        <view class="time-value" wx:if="{{preferredDate && preferredTime}}">
          <text>{{preferredDate}} {{preferredTime}}</text>
          <text class="time-change" bindtap="openTimePicker">修改</text>
        </view>
        <view class="time-value" wx:else>
          <text>不限</text>
          <text class="time-change" bindtap="openTimePicker">设置</text>
        </view>
      </view>
    </view>

    <!-- 司机备注 -->
    <view class="card">
      <view class="card-title">备注（选填）</view>
      <textarea
        class="remark-input"
        placeholder="如有其他需求请说明"
        value="{{driverRemark}}"
        bindinput="onRemarkInput"
        maxlength="500"
        show-length
      />
    </view>

    <!-- 门店安排提示（管理员选门店时）-->
    <view class="card" wx:if="{{!fleetConfig.allowDriverSelectStore}}">
      <view class="fleet-tip-card">
        <view class="tip-icon">💡</view>
        <view class="tip-content">
          <view class="tip-title">联系门店确认时间</view>
          <view class="tip-text">提交后车队管理员将为您安排门店，请留意订单状态并及时联系门店确认到店时间</view>
        </view>
      </view>
    </view>
    <!-- 提交按钮 -->
    <view class="submit-container">
      <button
        class="submit-btn"
        bindtap="onSubmit"
        disabled="{{submitting}}"
      >
        {{submitting ? '提交中...' : '提交保养申请'}}
      </button>
    </view>

    <!-- 时间选择器 -->
    <view class="picker-mask" wx:if="{{showTimePicker}}" bindtap="closeTimePicker">
      <view class="picker-popup" catchtap="">
        <view class="picker-header">
          <text class="picker-title">选择到店时间</text>
          <text class="picker-close" bindtap="closeTimePicker">✕</text>
        </view>

        <!-- 不限选项 -->
        <view class="time-unlimited-option" bindtap="selectTimeUnlimited">
          <text class="option-icon">⏰</text>
          <text class="option-title">不限到店时间</text>
          <text class="option-desc">提交后由门店联系您确认时间</text>
        </view>

        <!-- 日期选择 -->
        <view class="date-section">
          <picker
            mode="date"
            value="{{preferredDate}}"
            start="{{today}}"
            bindchange="onDateChange"
          >
            <view class="date-picker">
              <text class="date-picker-text">{{preferredDate || '选择日期'}}</text>
            </view>
          </picker>

          <!-- 时间选择 -->
          <view class="time-section">
            <scroll-view class="time-slots" scroll-y>
              <view
                class="time-slot-item"
                wx:for="{{timeSlots}}"
                wx:key="*this"
                data-time="{{item}}"
                bindtap="selectTimeSlot"
              >
                {{item}}
              </view>
            </scroll-view>
          </view>
        </view>
      </view>
    </view>

    <!-- 修改地址选择器 -->
    <view class="picker-mask" wx:if="{{showLocationPicker}}" bindtap="closeLocationPicker">
      <view class="location-picker-popup" catchtap="">
        <view class="picker-header">
          <text class="picker-title">修改车辆位置</text>
          <text class="picker-close" bindtap="closeLocationPicker">✕</text>
        </view>

        <button class="location-option" bindtap="onChooseCurrentLocation">
          <text class="option-icon">📍</text>
          <text class="option-title">当前位置</text>
          <text class="option-desc">{{serviceLocation.address}}</text>
        </button>

        <button class="location-option" bindtap="onChooseFromContacts">
          <text class="option-icon">⭐</text>
          <text class="option-title">常用地址</text>
          <text class="option-desc">从地址簿选择</text>
        </button>
      </view>
    </view>

    <!-- 门店选择器 -->
    <view class="picker-mask" wx:if="{{showStorePicker}}" bindtap="closeStorePicker">
      <view class="store-picker-popup" catchtap="">
        <view class="picker-header">
          <text class="picker-title">选择保养门店</text>
          <text class="picker-close" bindtap="closeStorePicker">✕</text>
        </view>

        <scroll-view class="store-list" scroll-y>
          <view
            class="store-item {{selectedStoreIndex === index ? 'active' : ''}}"
            wx:for="{{stores}}"
            wx:key="_id"
            data-index="{{index}}"
            bindtap="onStoreSelect"
          >
            <view class="store-item-info">
              <text class="store-item-name">{{item.name}}</text>
              <text class="store-item-address" wx:if="{{item.address}}">
                {{item.address.city || ''}}{{item.address.district || ''}}{{item.address.detail || item.address.full || ''}}
              </text>
              <text class="store-item-distance" wx:if="{{item.distance}}">
                距离 {{item.distance}}km
              </text>
            </view>
            <view class="store-item-check" wx:if="{{selectedStoreIndex === index}}">✓</view>
          </view>
        </scroll-view>

        <view class="store-picker-footer">
          <button class="store-picker-cancel" bindtap="closeStorePicker">取消</button>
          <button class="store-picker-confirm" bindtap="onConfirmStoreSelect">确认</button>
        </view>
      </view>
    </view>

    <!-- 门店详情弹窗 -->
    <view class="picker-mask" wx:if="{{showStoreDetail}}" bindtap="onCloseStoreDetail">
      <view class="store-detail-popup" catchtap="">
        <view class="picker-header">
          <text class="picker-title">门店详情</text>
          <text class="picker-close" bindtap="onCloseStoreDetail">✕</text>
        </view>

        <scroll-view class="store-detail-content" scroll-y>
          <view class="store-detail-name">{{storeDetail.name}}</view>
          <view class="store-detail-address" wx:if="{{storeDetail.address}}">
            {{storeDetail.address.city || ''}}{{storeDetail.address.district || ''}}{{storeDetail.address.detail || storeDetail.address.full || ''}}
          </view>
          <view class="store-detail-phone" wx:if="{{storeDetail.phone}}">
            <text>电话：{{storeDetail.phone}}</text>
            <text class="store-call-btn" bindtap="onCallStore">拨打电话</text>
          </view>

          <view class="store-reviews" wx:if="{{storeDetailReviews.length > 0}}">
            <view class="reviews-title">用户评价</view>
            <view class="review-item" wx:for="{{storeDetailReviews}}" wx:key="_id">
              <view class="review-header">
                <text class="reviewer-name">{{item.reviewerId.nickname || '匿名用户'}}</text>
                <text class="review-rating">{{item.overallRating}}★</text>
              </view>
              <text class="review-comment" wx:if="{{item.comment}}">{{item.comment}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{vehicleLoading || packagesLoading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{vehicleLoading ? '加载车辆信息...' : '加载推荐套餐...'}}</text>
    </view>
  </scroll-view>
</view>
