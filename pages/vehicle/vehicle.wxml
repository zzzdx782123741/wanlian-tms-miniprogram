<!--pages/vehicle/vehicle.wxml - 我的车辆页面-->
<view class="page">
  <!-- 无权限提示 -->
  <view class="no-permission" wx:if="{{!hasPermission}}">
    <text class="no-permission-icon">🔒</text>
    <text class="no-permission-title">暂无访问权限</text>
    <text class="no-permission-text">技师角色无法访问车辆管理功能</text>
    <button class="back-home-btn" bindtap="goHome">
      返回首页
    </button>
  </view>

  <!-- 有权限时显示内容 -->
  <view wx:else>
    <!-- 顶部标题栏 -->
    <view class="header">
      <view class="header-title">我的车辆</view>
      <view class="header-subtitle">查看与管理您的车辆信息</view>
    </view>

    <!-- 车辆列表 -->
    <view class="vehicle-list">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && vehicles.length === 0}}">
      <text class="empty-icon">🚚</text>
      <text class="empty-text">暂无车辆记录</text>
      <text class="empty-hint">请联系管理员为您分配车辆</text>
    </view>

    <!-- 车辆卡片 -->
    <view
      class="vehicle-card"
      wx:for="{{vehicles}}"
      wx:key="_id"
    >
      <!-- 车辆头部 -->
      <view class="vehicle-header">
        <view class="vehicle-plate">{{item.plateNumber}}</view>
        <view class="vehicle-status status-{{item.status}}">
          {{item.statusText}}
        </view>
      </view>

      <!-- 车辆详情 -->
      <view class="vehicle-details">
        <view class="detail-row">
          <text class="detail-icon">🚗</text>
          <view class="detail-info">
            <text class="detail-label">品牌车型</text>
            <text class="detail-value">{{item.brand}} {{item.model}}</text>
          </view>
        </view>

        <view class="detail-row" wx:if="{{item.year}}">
          <text class="detail-icon">📅</text>
          <view class="detail-info">
            <text class="detail-label">年份</text>
            <text class="detail-value">{{item.year}}年</text>
          </view>
        </view>

        <view class="detail-row" wx:if="{{item.vin}}">
          <text class="detail-icon">🔢</text>
          <view class="detail-info">
            <text class="detail-label">车架号</text>
            <text class="detail-value">{{item.vin}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 - 三列紧凑布局 -->
      <view class="vehicle-actions">
        <button
          class="action-btn action-report"
          bindtap="onReport"
          data-vehicle-id="{{item._id}}"
          disabled="{{item.status !== 'normal'}}"
        >
          <text class="btn-icon">🔧</text>
          <text>报修</text>
        </button>
        <button
          class="action-btn action-maintenance"
          bindtap="onMaintenance"
          data-vehicle-id="{{item._id}}"
          disabled="{{item.status !== 'normal'}}"
        >
          <text class="btn-icon">🛠️</text>
          <text>保养</text>
        </button>
        <button
          class="action-btn action-records"
          bindtap="onViewOrders"
          data-vehicle-id="{{item._id}}"
          data-vehicle-plate="{{item.plateNumber}}"
        >
          <text class="btn-icon">📋</text>
          <text>订单</text>
        </button>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
  </view>
</view>
