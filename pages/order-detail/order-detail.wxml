<!--pages/order-detail/order-detail.wxml - 订单详情页面-->
<view class="page {{showStorePicker || showStoreDetail || showPackagePicker ? 'page-modal-open' : ''}}">
  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 订单详情 -->
  <view class="order-detail" wx:if="{{!loading && order}}">
    <!-- 顶部状态卡片 -->
    <view class="status-card status-{{order.status}}">
      <image class="status-icon" src="{{order.statusIcon}}" mode="aspectFit" />
      <view class="status-info">
        <view class="status-text">{{order.statusText}}</view>
        <view class="status-hint">{{order.statusHint}}</view>
      </view>
    </view>

    <!-- 进度时间线 -->
    <view class="timeline" wx:if="{{order.timeline && order.timeline.length > 0}}">
      <view class="timeline-item" wx:for="{{order.timeline}}" wx:key="index">
        <view class="timeline-dot {{item.completed ? 'active' : ''}}"></view>
        <view class="timeline-content">
          <view class="timeline-title">{{item.title}}</view>
          <view class="timeline-time" wx:if="{{item.time}}">{{item.time}}</view>
        </view>
      </view>
    </view>

    <!-- 拒绝原因信息（被拒绝的订单显示） -->
    <view class="info-card reject-card" wx:if="{{order.status === 'rejected' && order.rejectReason}}">
      <view class="reject-header">
        <image class="reject-icon svg-icon-lg" src="/images/icons/x-circle.svg" mode="aspectFit" />
        <text class="reject-title">订单已被拒绝</text>
      </view>
      <view class="reject-reason">
        <text class="reject-reason-label">拒绝原因：</text>
        <text class="reject-reason-text">{{order.rejectReason}}</text>
      </view>
      <view class="reject-tip">请根据拒绝原因修改订单信息后重新提交</view>
    </view>

    <!-- 订单基本信息 -->
    <view class="info-card">
      <view class="card-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单编号</text>
        <text class="info-value">{{order.orderNumber}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">订单类型</text>
        <text class="info-value">{{order.typeText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">创建时间</text>
        <text class="info-value">{{order.createdAtText}}</text>
      </view>
    </view>

    <!-- 预约时间信息 -->
    <view class="info-card appointment-compact" wx:if="{{order.appointment && (order.appointment.expectedDate || order.appointment.expectedTimeSlot || order.appointment.confirmedDate)}}">
      <!-- 期望时间 - 主要显示 -->
      <view class="appointment-main" wx:if="{{order.appointment.expectedDate || order.appointment.expectedTimeSlot}}">
        <view class="appointment-header">
          <image class="appointment-icon" src="/images/icons/appointment-clock.svg" mode="aspectFit" />
          <text class="appointment-title">司机期望到店时间</text>
          <view class="appointment-status-tag appointment-{{order.appointment.status}}" wx:if="{{order.appointment.status}}">
            <image
              wx:if="{{order.appointment.statusIcon}}"
              class="appointment-status-icon"
              src="{{order.appointment.statusIcon}}"
              mode="aspectFit"
            />
            <text class="appointment-status-text">{{order.appointment.statusText}}</text>
            <!--
              {{order.appointment.status === 'pending' ? '待确认到店时间' : ''}}
              {{order.appointment.status === 'confirmed' ? '已确认' : ''}}
              {{order.appointment.status === 'adjusted' ? '已调整' : ''}}
            </text>
            -->
          </view>
        </view>
        <view class="appointment-time-display">
          <text class="time-date">{{order.appointment.expectedDate}}</text>
          <text class="time-slot">{{order.appointment.expectedTimeSlot}}</text>
        </view>
      </view>

      <!-- 确认时间 -->
      <view class="appointment-confirmed" wx:if="{{(order.appointment.status === 'confirmed' || order.appointment.status === 'adjusted') && order.appointment.confirmedDate}}">
        <view class="confirmed-label">门店已确认</view>
        <view class="confirmed-time">{{order.appointment.confirmedDate}} {{order.appointment.confirmedTimeSlot || ''}}</view>
      </view>

      <!-- 备注 -->
      <view class="appointment-remark" wx:if="{{order.appointment.remark}}">
        <text class="remark-text">{{order.appointment.remark}}</text>
      </view>

      <!-- 待确认提示 - 仅司机可见 -->
      <view class="appointment-hint" wx:if="{{order.appointment.status === 'pending' && userRole === 'DRIVER'}}">
        门店确认到店时间后将通知您
      </view>

      <!-- 已调整提示 -->
      <view class="appointment-hint adjusted" wx:if="{{order.appointment.status === 'adjusted'}}">
        门店已调整到店时间
      </view>
    </view>

    <!-- 车辆信息 -->
    <view class="info-card" bindtap="onVehicleDetail" data-vehicle-id="{{order.vehicleId._id}}">
      <view class="card-title">车辆信息</view>
      <view class="vehicle-info">
        <view class="vehicle-main">
          <text class="vehicle-plate">{{order.vehicleId.plateNumber}}</text>
          <text class="vehicle-model">{{order.vehicleId.brand}} {{order.vehicleId.model}}</text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
        <!-- 车队信息 -->
      <view class="fleet-info" wx:if="{{order.fleetId}}">
        <text class="fleet-label">归属车队：</text>
        <text class="fleet-name">{{order.fleetId.name}}</text>
      </view>
    </view>

    <!-- 司机信息（提交人信息） -->
    <view class="info-card" wx:if="{{order.reporterId}}">
      <view class="card-title">提交人信息</view>
      <view class="reporter-detail">
        <view class="reporter-name-row">
          <text class="reporter-name">{{order.reporterId.nickname}}</text>
          <view class="reporter-role" wx:if="{{order.reporterId.role && order.reporterId.role.type === 'DRIVER'}}">
            <image class="reporter-role-icon" src="/images/icons/role-driver.svg" mode="aspectFit" />
            <text class="reporter-role-text">司机</text>
          </view>
        </view>
        <view class="reporter-contact" wx:if="{{order.reporterId.phone}}">
          <image class="contact-icon svg-icon-md" src="/images/icons/phone.svg" mode="aspectFit" />
          <text class="contact-phone">{{order.reporterId.phone}}</text>
        </view>
      </view>
      <!-- 联系司机按钮 -->
      <button class="contact-btn" wx:if="{{order.reporterId.phone && userRole === 'FLEET_MANAGER'}}" bindtap="onContactReporter">
        联系司机
      </button>
    </view>

    <!-- 故障描述（维修订单） -->
    <view class="info-card" wx:if="{{order.type === 'repair'}}">
      <view class="card-title">故障描述</view>
      <view class="fault-content">{{order.faultDescription}}</view>
      <view class="info-row" wx:if="{{order.milestone}}">
        <text class="info-label">当前里程</text>
        <text class="info-value">{{order.milestone}} 公里</text>
      </view>
      <view class="fault-images" wx:if="{{order.milestonePhotos && order.milestonePhotos.length > 0}}">
        <view class="photos-title">里程照片</view>
        <image
          class="fault-image"
          wx:for="{{order.milestonePhotos}}"
          wx:for-item="image"
          wx:key="*this"
          src="{{image}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{image}}"
          data-urls="{{order.milestonePhotos}}"
        />
      </view>
      <!-- 故障图片 -->
      <view class="fault-images" wx:if="{{order.faultImages && order.faultImages.length > 0}}">
        <view class="photos-title">故障照片</view>
        <image
          class="fault-image"
          wx:for="{{order.faultImages}}"
          wx:for-item="image"
          wx:key="*this"
          src="{{image}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{image}}"
          data-urls="{{order.faultImages}}"
        />
      </view>
    </view>

    <!-- 车辆位置（所有订单都显示） -->
    <view class="info-card" wx:if="{{order.serviceLocation && order.serviceLocation.address}}">
      <view class="card-title">车辆位置</view>
      <view class="service-location-info">
        <image class="location-icon svg-icon-md" src="/images/icons/location-pin.svg" mode="aspectFit" />
        <text class="location-text">{{order.serviceLocation.address}}</text>
      </view>
    </view>

    <!-- 保养信息（保养订单） -->
    <view class="info-card" wx:if="{{order.type === 'maintenance'}}">
      <view class="card-title">保养信息</view>
      <view class="maint-info-row">
        <text class="maint-label">保养类型：</text>
        <text class="maint-value">{{order.maintenanceOrder.maintenanceTypeName}}</text>
      </view>
      <view class="maint-info-row">
        <text class="maint-label">套餐：</text>
        <text class="maint-value">{{order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier}}</text>
      </view>
      <view class="maint-package-highlight {{(selectedPackageId || order.maintenanceOrder.packageId || order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier) ? 'selected' : 'pending'}}">
        <view class="maint-package-highlight-head">
          <text class="maint-package-highlight-title">套餐状态</text>
          <text class="maint-package-highlight-badge {{(selectedPackageId || order.maintenanceOrder.packageId || order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier) ? 'selected' : 'pending'}}">
            {{(selectedPackageId || order.maintenanceOrder.packageId || order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier) ? '已选择' : '待选择'}}
          </text>
        </view>
        <text class="maint-package-highlight-name">
          {{selectedPackageName || order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier || '暂未选择保养套餐'}}
        </text>
        <text class="maint-package-highlight-desc">
          {{(selectedPackageId || order.maintenanceOrder.packageId || order.maintenanceOrder.packageName || order.maintenanceOrder.selectedTier) ? '当前套餐已展示在订单中，点击底部区域可更换套餐。' : '请在页面底部先选择门店套餐，再继续审批流程。'}}
        </text>
      </view>
      <view class="maint-info-row" wx:if="{{order.maintenanceOrder.serviceLocation}}">
        <text class="maint-label">服务地址：</text>
        <text class="maint-value">{{order.maintenanceOrder.serviceLocation.address}}</text>
      </view>
      <view class="maint-info-row" wx:if="{{order.maintenanceOrder.preferredTime}}">
        <text class="maint-label">期望时间：</text>
        <text class="maint-value">{{order.maintenanceOrder.preferredTime}}</text>
      </view>
      <view class="maint-info-row" wx:if="{{order.maintenanceOrder.driverRemark}}">
        <text class="maint-label">司机备注：</text>
        <text class="maint-value">{{order.maintenanceOrder.driverRemark}}</text>
      </view>
      <!-- 车队审批后显示 -->
      <view class="maint-approval" wx:if="{{order.maintenanceOrder.approvedAt}}">
        <view class="approval-divider"></view>
        <view class="maint-info-row" wx:if="{{order.maintenanceOrder.confirmedStoreId}}">
          <text class="maint-label">确认门店：</text>
          <text class="maint-value">{{order.maintenanceOrder.confirmedStoreName}}</text>
        </view>
        <view class="maint-info-row" wx:if="{{order.maintenanceOrder.finalAmount}}">
          <text class="maint-label">最终金额：</text>
          <text class="maint-value price">¥{{order.maintenanceOrder.finalAmount}}</text>
        </view>
        <view class="maint-info-row" wx:if="{{order.maintenanceOrder.fleetRemark}}">
          <text class="maint-label">车队备注：</text>
          <text class="maint-value">{{order.maintenanceOrder.fleetRemark}}</text>
        </view>
      </view>
    </view>

    <!-- 门店信息（已接单后显示） -->
    <view class="info-card" wx:if="{{order.storeId}}">
      <view class="card-title">维修门店</view>
      <view class="store-info">
        <view class="store-name">{{order.storeId.name}}</view>
        <view class="store-detail">
          <image class="detail-icon svg-icon-md" src="/images/icons/location-pin.svg" mode="aspectFit" />
          <text>{{order.storeId.address.city}} {{order.storeId.address.district}} {{order.storeId.address.detail}}</text>
        </view>
        <view class="store-detail" wx:if="{{order.storeId.contact && order.storeId.contact.phone}}">
          <image class="detail-icon svg-icon-md" src="/images/icons/phone.svg" mode="aspectFit" />
          <text>{{order.storeId.contact.phone}}</text>
        </view>
      </view>
      <!-- 司机和车队管理员可以联系门店，门店技师不需要 -->
      <button class="contact-btn" wx:if="{{userRole !== 'STORE_TECHNICIAN' && userRole !== 'STORE_MANAGER'}}" bindtap="onContactStore">
        联系门店
      </button>
    </view>

    <!-- 接车检查信息（门店检查后显示） -->
    <view class="info-card" wx:if="{{order.receiveCheck && (order.receiveCheck.mileage || order.receiveCheck.diagnosis || order.receiveCheck.checkinPhotos)}}">
      <view class="check-info">
        <view class="info-row" wx:if="{{order.receiveCheck.mileage}}">
          <text class="info-label">当前里程</text>
          <text class="info-value">{{order.receiveCheck.mileage}} 公里</text>
        </view>
        <view class="check-diagnosis" wx:if="{{order.receiveCheck.diagnosis}}">
          <view class="diagnosis-label">诊断结果</view>
          <text class="diagnosis-text">{{order.receiveCheck.diagnosis}}</text>
        </view>
        <!-- 接车检查照片 -->
        <view class="check-photos" wx:if="{{order.receiveCheck.checkinPhotos && order.receiveCheck.checkinPhotos.length > 0}}">
          <image
            class="check-photo"
            wx:for="{{order.receiveCheck.checkinPhotos}}"
            wx:for-item="photo"
            wx:key="*this"
            src="{{photo}}"
            mode="aspectFill"
            bindtap="onPreviewImage"
            data-url="{{photo}}"
            data-urls="{{order.receiveCheck.checkinPhotos}}"
          />
        </view>
      </view>
    </view>

    <!-- 维修报价（已报价后显示） -->
    <view class="info-card" wx:if="{{order.quote && order.quote.items && order.quote.items.length > 0}}">
      <view class="card-title">维修报价</view>
      <view class="quote-items">
        <view class="quote-item" wx:for="{{order.quote.items}}" wx:key="item">
          <view class="item-name">{{item.item}}</view>
          <view class="item-price">¥{{item.price}} × {{item.quantity}}</view>
          <view class="item-subtotal">¥{{item.price * item.quantity}}</view>
        </view>
      </view>
      <view class="quote-total">
        <text class="total-label">总计：</text>
        <text class="total-value">¥{{order.quote.total}}</text>
      </view>
      <!-- 报价图片 -->
      <view class="quote-images" wx:if="{{order.quote.images && order.quote.images.length > 0}}">
        <image
          class="quote-image"
          wx:for="{{order.quote.images}}"
          wx:for-item="image"
          wx:key="*this"
          src="{{image}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{image}}"
          data-urls="{{order.quote.images}}"
        />
      </view>
    </view>

    <!-- 维修日志 -->
    <view class="info-card" wx:if="{{order.logs && order.logs.length > 0}}">
      <view class="card-title">维修日志</view>
      <view class="log-list">
        <view class="log-item" wx:for="{{order.logs}}" wx:key="_id">
          <view class="log-header">
            <text class="log-operator">{{item.operatorId.nickname}}</text>
            <text class="log-time">{{item.createdAtText}}</text>
          </view>
          <view class="log-content">{{item.content}}</view>
          <!-- 日志图片 -->
          <view class="log-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              class="log-image"
              wx:for="{{item.images}}"
              wx:for-item="image"
              wx:key="*this"
              src="{{image}}"
              mode="aspectFill"
              bindtap="onPreviewImage"
              data-url="{{image}}"
              data-urls="{{item.images}}"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 完工信息（已完工后显示） -->
    <view class="info-card" wx:if="{{order.completion}}">
      <view class="card-title">完工信息</view>
      <view class="completion-content">{{order.completion.description}}</view>
      <!-- 完工图片 -->
      <view class="completion-images" wx:if="{{order.completion.images && order.completion.images.length > 0}}">
        <image
          class="completion-image"
          wx:for="{{order.completion.images}}"
          wx:for-item="image"
          wx:key="*this"
          src="{{image}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{image}}"
          data-urls="{{order.completion.images}}"
        />
      </view>
      <!-- 确认信息 -->
      <view class="confirm-info" wx:if="{{order.completion.confirmedBy}}">
        <view class="confirm-row">
          <text class="confirm-icon">✓</text>
          <text class="confirm-label">确认状态：</text>
          <text class="confirm-value">已确认</text>
        </view>
        <view class="confirm-time" wx:if="{{order.completion.confirmedAtText}}">
          确认时间：{{order.completion.confirmedAtText}}
        </view>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="action-bar {{showStorePicker || showStoreDetail || showPackagePicker ? 'action-bar-hidden' : ''}}">
      <!-- 车队管理员审批区域 - 待车队审批状态 -->
      <view class="fleet-approve-section" wx:if="{{order.status === 'awaiting_fleet_approval' && userRole === 'FLEET_MANAGER'}}">
        <!-- 门店选择提示 -->
        <view class="approve-tip" wx:if="{{!order.storeId && !selectedStoreId}}">
          <image class="tip-icon svg-icon-md" src="/images/icons/lightbulb.svg" mode="aspectFit" />
          <text class="tip-text">请先为订单分配门店，再进行审批</text>
        </view>

        <!-- 选择门店按钮（未分配门店时显示） -->
        <button
          class="action-btn select-store"
          wx:if="{{!order.storeId && !selectedStoreId}}"
          bindtap="onSelectStore"
        >
          选择门店
        </button>

        <!-- 已选门店提示（点击可重选） -->
        <view class="selected-store-tip" wx:if="{{order.storeId || selectedStoreId}}" bindtap="onSelectStore">
          <view class="selected-store-content">
            <image class="store-icon svg-icon-md" src="/images/icons/store.svg" mode="aspectFit" />
            <view class="selected-store-info">
              <text class="store-name">{{selectedStoreName || order.storeId.name}}</text>
              <text class="store-hint">点击可更换门店</text>
            </view>
            <text class="store-change-icon">›</text>
          </view>
        </view>

        <!-- 保养订单：套餐选择区域 -->
        <view class="package-selection-panel" wx:if="{{order.type === 'maintenance' && (order.storeId || selectedStoreId)}}">
          <view class="package-selection-header">
            <view class="package-selection-title-wrap">
              <image class="package-selection-icon svg-icon-md" src="/images/icons/package-box.svg" mode="aspectFit" />
              <text class="package-selection-title">保养套餐</text>
            </view>
            <text class="package-selection-badge {{(selectedPackageId || order.maintenanceOrder.packageId) ? 'selected' : 'pending'}}">
              {{(selectedPackageId || order.maintenanceOrder.packageId) ? '已选择' : '待选择'}}
            </text>
          </view>

          <view class="package-selection-body" wx:if="{{!selectedPackageId && !order.maintenanceOrder.packageId}}">
            <view class="package-empty-state">
              <text class="package-empty-title">当前还没有为该订单选择套餐</text>
              <text class="package-empty-desc">请选择当前门店可提供的保养套餐后再提交审批</text>
            </view>
            <button
              class="action-btn select-package"
              bindtap="onSelectPackage"
            >
              立即选择保养套餐
            </button>
          </view>

          <view class="selected-package-tip" wx:if="{{selectedPackageId || order.maintenanceOrder.packageId}}" bindtap="onSelectPackage">
            <view class="selected-package-content">
              <image class="package-icon svg-icon-md" src="/images/icons/package-box.svg" mode="aspectFit" />
              <view class="selected-package-info">
                <text class="package-name">{{selectedPackageName || order.maintenanceOrder.packageName}}</text>
                <text class="package-hint">已为该订单锁定套餐，点击可重新选择</text>
              </view>
              <text class="package-change-icon">›</text>
            </view>
          </view>
        </view>

        <!-- 审批按钮（已分配门店后显示） -->
        <!-- 保养订单：已选门店和套餐后才能审批 -->
        <!-- 维修订单：已选门店后即可审批 -->
        <button
          class="action-btn approve"
          wx:if="{{(order.type === 'maintenance' && (order.storeId || selectedStoreId) && (selectedPackageId || order.maintenanceOrder.packageId)) || (order.type === 'repair' && (order.storeId || selectedStoreId))}}"
          bindtap="onFleetApproveWithStore"
        >
          审批通过
        </button>

        <!-- 拒绝按钮（随时可用） -->
        <button
          class="action-btn reject"
          bindtap="onFleetRejectOrder"
        >
          审批拒绝
        </button>
      </view>

      <!-- 车队管理员审批按钮 - 待审批报价状态 -->
      <button
        class="action-btn approve"
        wx:if="{{order.status === 'awaiting_approval' && userRole === 'FLEET_MANAGER'}}"
        bindtap="onApproveQuote"
        data-approved="{{true}}"
      >
        批准报价
      </button>
      <button
        class="action-btn reject"
        wx:if="{{order.status === 'awaiting_approval' && userRole === 'FLEET_MANAGER'}}"
        bindtap="onApproveQuote"
        data-approved="{{false}}"
      >
        拒绝报价
      </button>

      <!-- 车队管理员审批按钮 - 待审批增项状态 -->
      <button
        class="action-btn approve"
        wx:if="{{order.status === 'awaiting_addon_approval' && userRole === 'FLEET_MANAGER'}}"
        bindtap="onApproveAddon"
        data-approved="{{true}}"
      >
        批准增项
      </button>
      <button
        class="action-btn reject"
        wx:if="{{order.status === 'awaiting_addon_approval' && userRole === 'FLEET_MANAGER'}}"
        bindtap="onApproveAddon"
        data-approved="{{false}}"
      >
        拒绝增项
      </button>

      <!-- 门店管理员操作按钮 -->
      <button
        class="action-btn primary"
        wx:if="{{order.status === 'awaiting_time_confirmation' && userRole === 'STORE_MANAGER'}}"
        bindtap="onConfirmAppointmentTime"
      >
        确认到店时间
      </button>

      <!-- 门店技师操作按钮 -->
      <button
        class="action-btn primary"
        wx:if="{{order.status === 'pending_assessment' && userRole === 'STORE_TECHNICIAN'}}"
        bindtap="onSubmitQuote"
      >
        接车检查与报价
      </button>
      <button
        class="action-btn primary"
        wx:if="{{order.status === 'in_repair' && userRole === 'STORE_TECHNICIAN'}}"
        bindtap="onCompleteOrder"
      >
        提交完工
      </button>

      <!-- 司机确认按钮 -->
      <button
        class="action-btn reject"
        wx:if="{{order.canCancelOrder}}"
        bindtap="onCancelOrder"
      >
        <text class="btn-icon">×</text>
        撤销订单
      </button>
      <button
        class="action-btn confirm"
        wx:if="{{userRole === 'DRIVER' && (order.status === 'pending_confirmation' || (order.status === 'completed' && !(order.completion && order.completion.confirmedBy)))}}"
        bindtap="onConfirmOrder"
      >
        <text class="btn-icon">✓</text>
        确认完工
      </button>

      <!-- 司机去评价按钮（已完成且已确认但未评价，15天内） -->
      <button
        class="action-btn review"
        wx:if="{{order.status === 'completed' && userRole === 'DRIVER' && order.completion && order.completion.confirmedBy && !order.reviewed && order.canReview}}"
        bindtap="onReviewOrder"
      >
        立即评价
      </button>

      <!-- 司机重新提交按钮（被拒绝的订单） -->
      <button
        class="action-btn resubmit"
        wx:if="{{order.canResubmit && userRole === 'DRIVER'}}"
        bindtap="onResubmitOrder"
      >
        重新提交
      </button>

      <!-- 查看拒绝原因按钮（非司机角色查看被拒绝订单） -->
      <button
        class="action-btn info"
        wx:if="{{order.status === 'rejected' && userRole !== 'DRIVER'}}"
        bindtap="onViewRejectReason"
      >
        查看拒绝原因
      </button>

      <!-- 已确认提示 -->
      <view class="confirmed-notice" wx:if="{{order.status === 'completed' && order.completion && order.completion.confirmedBy}}">
        <image class="notice-icon svg-icon-md" src="/images/icons/check-circle.svg" mode="aspectFit" />
        <text class="notice-text">您已确认完工</text>
      </view>
    </view>
  </view>

  <!-- 门店选择弹窗 -->
  <view class="store-picker-mask" wx:if="{{showStorePicker}}" bindtap="onCloseStorePicker">
    <view class="store-picker-popup" catchtap="">
      <view class="store-picker-header">
        <text class="store-picker-title">选择门店</text>
        <text class="store-picker-close" bindtap="onCloseStorePicker">✕</text>
      </view>
      <scroll-view class="store-picker-list" scroll-y>
        <view
          class="store-picker-item {{selectedStoreId === item._id ? 'active' : ''}}"
          wx:for="{{storeList}}"
          wx:key="_id"
        >
          <view class="store-item-main" bindtap="onSelectStoreItem" data-store-id="{{item._id}}" data-store-name="{{item.name}}">
            <view class="store-item-header">
              <view class="store-item-name">{{item.name}}</view>
              <view class="store-item-check" wx:if="{{selectedStoreId === item._id}}">✓</view>
            </view>
            <view class="store-item-info">
              <text class="store-item-distance" wx:if="{{item.distance !== undefined}}">{{item.distance}}km</text>
              <view class="store-item-location" wx:if="{{item.address && item.address.district}}">
                <image class="store-item-inline-icon svg-icon-sm" src="/images/icons/location-pin.svg" mode="aspectFit" />
                <text>{{item.address.district}}</text>
              </view>
              <text class="store-item-rating" wx:if="{{item.ratingStats && item.ratingStats.overallRating > 0}}">
                {{item.ratingStats.overallRating}}分
                <text wx:if="{{item.ratingStats.reviewCount > 0}}">（{{item.ratingStats.reviewCount}}条）</text>
              </text>
              <text class="store-item-rating" wx:else>暂无评价</text>
            </view>
            <view class="store-item-details">
              <view class="store-item-detail" wx:if="{{item.businessHours}}">
                <image class="detail-icon svg-icon-sm" src="/images/icons/clock.svg" mode="aspectFit" />
                <text class="detail-text">{{item.businessHours}}</text>
              </view>
              <view class="store-item-detail" wx:if="{{item.contact && item.contact.phone}}">
                <image class="detail-icon svg-icon-sm" src="/images/icons/phone.svg" mode="aspectFit" />
                <text class="detail-text">{{item.contact.phone}}</text>
              </view>
            </view>
          </view>
          <view class="store-item-actions">
            <button class="store-detail-btn" catchtap="onViewStoreDetail" data-store="{{item}}">查看详情</button>
          </view>
        </view>
      </scroll-view>
      <view class="store-picker-footer">
        <button class="store-picker-cancel" bindtap="onCloseStorePicker">取消</button>
        <button class="store-picker-confirm" bindtap="onConfirmStoreSelect" disabled="{{!selectedStoreId}}">确认选择</button>
      </view>
    </view>
  </view>

  <!-- 门店详情弹窗 -->
  <view class="store-detail-mask" wx:if="{{showStoreDetail}}" bindtap="onCloseStoreDetail">
    <view class="store-detail-popup" catchtap="">
      <view class="store-detail-header">
        <view class="store-detail-title">{{storeDetail.name}}</view>
        <text class="store-detail-close" bindtap="onCloseStoreDetail">✕</text>
      </view>

      <scroll-view class="store-detail-content" scroll-y>
        <!-- 评分概览 -->
        <view class="detail-rating-card">
          <view class="rating-overview">
            <text class="rating-score">{{storeDetail.ratingStats.overallRating || 0}}</text>
            <view class="rating-stars">
              <text class="star">{{storeDetail.ratingStats.overallRating >= 1 ? '★' : '☆'}}</text>
              <text class="star">{{storeDetail.ratingStats.overallRating >= 2 ? '★' : '☆'}}</text>
              <text class="star">{{storeDetail.ratingStats.overallRating >= 3 ? '★' : '☆'}}</text>
              <text class="star">{{storeDetail.ratingStats.overallRating >= 4 ? '★' : '☆'}}</text>
              <text class="star">{{storeDetail.ratingStats.overallRating >= 5 ? '★' : '☆'}}</text>
            </view>
            <text class="rating-count">{{storeDetail.ratingStats.reviewCount || 0}}条评价</text>
          </view>
        </view>

        <!-- 门店信息 -->
        <view class="detail-section">
          <view class="detail-section-title">门店信息</view>
          <view class="detail-info-list">
            <view class="detail-info-item" wx:if="{{storeDetail.address}}">
              <image class="info-icon svg-icon-md" src="/images/icons/location-pin.svg" mode="aspectFit" />
              <text class="info-text">{{storeDetail.address.city}} {{storeDetail.address.district}} {{storeDetail.address.detail}}</text>
            </view>
            <view class="detail-info-item" wx:if="{{storeDetail.businessHours}}">
              <image class="info-icon svg-icon-md" src="/images/icons/clock.svg" mode="aspectFit" />
              <text class="info-text">{{storeDetail.businessHours}}</text>
            </view>
            <view class="detail-info-item" wx:if="{{storeDetail.contact.phone}}">
              <image class="info-icon svg-icon-md" src="/images/icons/phone.svg" mode="aspectFit" />
              <text class="info-text">{{storeDetail.contact.phone}}</text>
            </view>
          </view>
        </view>

        <!-- 最近评价 -->
        <view class="detail-section" wx:if="{{storeDetailReviews && storeDetailReviews.length > 0}}">
          <view class="detail-section-title">最近评价</view>
          <view class="review-list">
            <view class="review-item" wx:for="{{storeDetailReviews}}" wx:key="_id" wx:for-item="review">
              <view class="review-header">
                <view class="review-author">{{review.anonymous ? '匿名用户' : review.reviewerId.nickname}}</view>
                <view class="review-rating">
                  <text class="review-star" wx:for="{{5}}" wx:for-item="star" wx:key="*this">
                    {{star <= review.overallRating ? '★' : '☆'}}
                  </text>
                </view>
              </view>
              <view class="review-comment" wx:if="{{review.comment}}">{{review.comment}}</view>
              <view class="review-time">{{review.createdAtText}}</view>
            </view>
          </view>
        </view>

        <!-- 暂无评价提示 -->
        <view class="detail-section" wx:else>
          <view class="no-reviews">
            <image class="no-reviews-icon svg-icon-lg" src="/images/icons/comment-bubble.svg" mode="aspectFit" />
            <text class="no-reviews-text">暂无评价</text>
            <text class="no-reviews-hint">成为第一个评价的人</text>
          </view>
        </view>
      </scroll-view>

      <!-- 底部操作 -->
      <view class="store-detail-footer">
        <button class="detail-close-btn" bindtap="onCloseStoreDetail">关闭</button>
      </view>
    </view>
  </view>

  <!-- 套餐选择弹窗（车队管理员审批保养订单） -->
  <view class="package-picker-mask" wx:if="{{showPackagePicker}}" bindtap="onClosePackagePicker" catchtouchmove="noop">
    <view class="package-picker-popup" catchtap="noop">
      <view class="package-picker-header">
        <text class="package-picker-title">选择保养套餐</text>
        <text class="package-picker-close" bindtap="onClosePackagePicker">✕</text>
      </view>
      <scroll-view class="package-picker-content" scroll-y enhanced="{{true}}" show-scrollbar="{{false}}">
        <!-- 小保养分类 -->
        <view class="package-category" wx:if="{{categorizedPackages.minor.packages.length > 0}}">
          <view class="category-header" data-category="minor" bindtap="onToggleCategory">
            <view class="category-info">
              <image class="category-icon svg-icon-md" src="/images/icons/oil-drop.svg" mode="aspectFit" />
              <text class="category-name">小保养</text>
              <text class="category-count">{{categorizedPackages.minor.packages.length}} 个套餐</text>
            </view>
            <text class="category-arrow {{categorizedPackages.minor.expanded ? 'expanded' : ''}}">▼</text>
          </view>
          <view class="category-packages" wx:if="{{categorizedPackages.minor.expanded}}">
            <view
              class="picker-package-item {{selectedPackageId === pkg._id ? 'active' : ''}}"
              wx:for="{{categorizedPackages.minor.packages}}"
              wx:key="_id"
              wx:for-item="pkg"
              bindtap="onSelectPackageItem"
              data-package-id="{{pkg._id}}"
              data-package-name="{{pkg.name}}"
            >
              <view class="package-item-main">
                <view class="package-item-header">
                  <text class="package-item-name">{{pkg.name}}</text>
                  <view class="package-item-check" wx:if="{{selectedPackageId === pkg._id}}">✓</view>
                </view>
                <text class="package-item-tier">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-item-price">¥{{pkg.price}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 大保养分类 -->
        <view class="package-category" wx:if="{{categorizedPackages.major.packages.length > 0}}">
          <view class="category-header" data-category="major" bindtap="onToggleCategory">
            <view class="category-info">
              <image class="category-icon svg-icon-md" src="/images/icons/wrench.svg" mode="aspectFit" />
              <text class="category-name">大保养</text>
              <text class="category-count">{{categorizedPackages.major.packages.length}} 个套餐</text>
            </view>
            <text class="category-arrow {{categorizedPackages.major.expanded ? 'expanded' : ''}}">▼</text>
          </view>
          <view class="category-packages" wx:if="{{categorizedPackages.major.expanded}}">
            <view
              class="picker-package-item {{selectedPackageId === pkg._id ? 'active' : ''}}"
              wx:for="{{categorizedPackages.major.packages}}"
              wx:key="_id"
              wx:for-item="pkg"
              bindtap="onSelectPackageItem"
              data-package-id="{{pkg._id}}"
              data-package-name="{{pkg.name}}"
            >
              <view class="package-item-main">
                <view class="package-item-header">
                  <text class="package-item-name">{{pkg.name}}</text>
                  <view class="package-item-check" wx:if="{{selectedPackageId === pkg._id}}">✓</view>
                </view>
                <text class="package-item-tier">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-item-price">¥{{pkg.price}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 专项保养分类 -->
        <view class="package-category" wx:if="{{categorizedPackages.special.packages.length > 0}}">
          <view class="category-header" data-category="special" bindtap="onToggleCategory">
            <view class="category-info">
              <image class="category-icon svg-icon-md" src="/images/icons/settings.svg" mode="aspectFit" />
              <text class="category-name">专项保养</text>
              <text class="category-count">{{categorizedPackages.special.packages.length}} 个套餐</text>
            </view>
            <text class="category-arrow {{categorizedPackages.special.expanded ? 'expanded' : ''}}">▼</text>
          </view>
          <view class="category-packages" wx:if="{{categorizedPackages.special.expanded}}">
            <view
              class="picker-package-item {{selectedPackageId === pkg._id ? 'active' : ''}}"
              wx:for="{{categorizedPackages.special.packages}}"
              wx:key="_id"
              wx:for-item="pkg"
              bindtap="onSelectPackageItem"
              data-package-id="{{pkg._id}}"
              data-package-name="{{pkg.name}}"
            >
              <view class="package-item-main">
                <view class="package-item-header">
                  <text class="package-item-name">{{pkg.name}}</text>
                  <view class="package-item-check" wx:if="{{selectedPackageId === pkg._id}}">✓</view>
                </view>
                <text class="package-item-tier">{{pkg.tierName || pkg.tier}}</text>
                <text class="package-item-price">¥{{pkg.price}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="package-empty" wx:if="{{categorizedPackages.minor.packages.length === 0 && categorizedPackages.major.packages.length === 0 && categorizedPackages.special.packages.length === 0}}">
          <image class="empty-icon svg-icon-xl" src="/images/icons/package-box.svg" mode="aspectFit" />
          <text class="empty-text">该门店暂无可用套餐</text>
        </view>
      </scroll-view>

      <!-- 底部操作按钮 -->
      <view class="package-picker-footer">
        <button class="package-picker-cancel" bindtap="onClosePackagePicker">取消</button>
        <button class="package-picker-confirm" bindtap="onConfirmPackageSelect" disabled="{{!selectedPackageId}}">确认选择</button>
      </view>
    </view>
  </view>
</view>
