<view class="page">
  <view class="user-profile-card">
    <image
      class="user-avatar"
      src="{{userInfo.avatar || '/images/icons/avatar.png'}}"
      mode="aspectFill"
    />
    <view class="user-info">
      <view class="user-name">{{userInfo.nickname || '微信用户'}}</view>
      <view class="user-role">{{roleText}}</view>
    </view>
  </view>

  <view class="stats-container">
    <view class="stat-item" bindtap="onMyOrders">
      <view class="stat-value">{{stats.totalOrders}}</view>
      <view class="stat-label">我的订单</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onSecondaryStatTap">
      <view class="stat-value">{{roleType === 'STORE_MANAGER' || roleType === 'STORE_TECHNICIAN' ? stats.pendingOrders : stats.vehicleCount}}</view>
      <view class="stat-label">{{secondaryStatLabel}}</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onMyOrders">
      <view class="stat-value">{{stats.completedOrders}}</view>
      <view class="stat-label">已完成</view>
    </view>
  </view>

  <view class="function-list">
    <view class="function-item" bindtap="onContactService">
      <text class="function-icon">📞</text>
      <view class="function-title">联系客服</view>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onAddressManage">
      <text class="function-icon">📍</text>
      <view class="function-title">常用地址</view>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onAbout">
      <text class="function-icon">ℹ️</text>
      <view class="function-title">关于平台</view>
      <text class="function-arrow">›</text>
    </view>
    <view class="function-item" bindtap="onLogout">
      <text class="function-icon">🚪</text>
      <view class="function-title">退出登录</view>
      <text class="function-arrow">›</text>
    </view>
  </view>
</view>
