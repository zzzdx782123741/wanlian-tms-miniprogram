/**
 * 首页样式 - 万联驿站2.0
 * 包含：司机端、车队管理员端、门店端、平台运营端
 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 120rpx;
}

/* 顶部装饰背景 */
.header-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, #F5F7FA 0%, #FFFFFF 100%);
  z-index: 0;
}

/* ==================== 车队管理员首页样式 ==================== */

.fleet-home {
  position: relative;
  z-index: 1;
  padding: var(--spacing-md);
}

/* 区域标题行（内联样式） */
.section-header-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.more-link {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* 数据概览区域 */
.stats-section {
  margin-bottom: var(--spacing-lg);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-sm);
}

.stat-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-sm);
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.stat-value {
  font-size: 44rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-value.highlight {
  color: #EF4444;
}

.stat-value.amount {
  font-size: 32rpx;
  color: #10B981;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 待办事项区域 */
.todo-section {
  margin-bottom: var(--spacing-lg);
}

.todo-group {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.todo-group-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: #F9FAFB;
  border-bottom: 1px solid var(--color-border-glass);
}

.todo-badge {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  margin-right: var(--spacing-sm);
}

.todo-badge.red {
  background: #FEF2F2;
  color: #EF4444;
}

.todo-badge.orange {
  background: #FFF7ED;
  color: #F59E0B;
}

.todo-badge.green {
  background: #ECFDF5;
  color: #10B981;
}

.todo-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.todo-list {
  padding: 0 var(--spacing-md);
}

.todo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--color-border-glass);
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item-left {
  flex: 1;
  min-width: 0;
}

.todo-plate {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.todo-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-type {
  color: var(--color-primary);
}

.todo-fault {
  color: var(--color-text-tertiary);
}

.todo-technician {
  color: #F59E0B;
}

.todo-amount {
  color: #EF4444;
  font-weight: var(--font-weight-semibold);
}

.todo-item-right {
  text-align: right;
  margin-left: var(--spacing-md);
}

.todo-reporter {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.todo-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* 空状态 */
.empty-todo {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 80rpx var(--spacing-xl);
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.empty-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: var(--spacing-md);
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
}

/* 快捷操作区域 */
.quick-section {
  margin-bottom: var(--spacing-lg);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-md);
}

.quick-btn {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.quick-btn:active {
  background: var(--color-bg-card-hover);
  transform: scale(0.98);
}

.quick-icon {
  font-size: 56rpx;
  margin-bottom: var(--spacing-xs);
}

.quick-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
}

/* 最近动态区域 */
.activity-section {
  margin-bottom: var(--spacing-lg);
}

.activity-list {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 0 var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.activity-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--color-border-glass);
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-icon {
  font-size: 32rpx;
  margin-right: var(--spacing-sm);
}

.activity-desc {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.activity-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ==================== 其他角色菜单样式 ==================== */

/* 菜单区域 */
.menu-section {
  position: relative;
  z-index: 1;
  padding: var(--spacing-md);
  margin-top: 40rpx;
}

.section-header {
  margin-bottom: var(--spacing-md);
  padding-left: var(--spacing-xs);
  border-left: 8rpx solid #667eea;
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: #1A202C;
  margin-bottom: 4rpx;
  padding-left: var(--spacing-sm);
}

.section-subtitle {
  font-size: var(--font-size-sm);
  color: #718096;
  padding-left: var(--spacing-sm);
}

/* 菜单网格 */
.menu-grid {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* 菜单卡片 */
.menu-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-glass);
}

.menu-card:active {
  background: var(--color-bg-card-hover);
  transform: scale(0.99);
}

.menu-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
}

.menu-content-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  padding: 40rpx var(--spacing-lg);
}

.menu-icon-wrapper {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F5FF;
  border-radius: var(--radius-md);
  margin-right: var(--spacing-md);
}

.menu-icon {
  font-size: 64rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  font-size: 40rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.menu-desc {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.menu-arrow {
  font-size: 56rpx;
  color: var(--color-text-tertiary);
  margin-left: var(--spacing-md);
}

/* 快捷操作 */
.quick-actions {
  position: relative;
  z-index: 1;
  padding: 0 var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: var(--color-text-primary);
  padding: 32rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-glass);
}

.action-btn:active {
  background: var(--color-bg-card-hover);
}

.dev-mode-btn {
  background: #FFF0F6;
  color: #C41D7F;
  border-color: #FFADD2;
}

.action-icon {
  font-size: 40rpx;
  margin-right: var(--spacing-sm);
}

.action-text {
  font-size: 32rpx;
  font-weight: var(--font-weight-semibold);
}

/* 底部 */
.footer {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.version {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
