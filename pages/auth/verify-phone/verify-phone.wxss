/* pages/auth/verify-phone/verify-phone.wxss */
.verify-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.code-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.send-code-btn {
  width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 26rpx;
  background: #667eea;
  color: #ffffff;
  border-radius: 12rpx;
  border: none;
}

.send-code-btn[disabled] {
  background: #cccccc;
  color: #999999;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  margin-top: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 12rpx;
  border: none;
}

.confirm-btn[disabled] {
  opacity: 0.6;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}
