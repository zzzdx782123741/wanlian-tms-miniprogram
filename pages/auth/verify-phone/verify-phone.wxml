<!--pages/auth/verify-phone/verify-phone.wxml-->
<view class="verify-container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">验证手机号</text>
    <text class="subtitle">首次登录需要验证手机号并绑定微信</text>
  </view>

  <view class="form">
    <!-- 手机号输入 -->
    <view class="form-item">
      <view class="label">手机号</view>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 验证码输入 -->
    <view class="form-item">
      <view class="label">验证码</view>
      <view class="code-wrapper">
        <input
          class="input code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button
          class="send-code-btn"
          disabled="{{countingDown}}"
          bindtap="onSendCode"
        >
          {{countingDown ? countdownText : '发送验证码'}}
        </button>
      </view>
    </view>

    <!-- 确认绑定按钮 -->
    <button
      class="confirm-btn"
      disabled="{{loading}}"
      bindtap="onConfirm"
    >
      {{loading ? '绑定中...' : '确认绑定'}}
    </button>

    <!-- 提示信息 -->
    <view class="tips">
      <text class="tip-icon">ℹ️</text>
      <text class="tip-text">请输入系统登记的手机号，验证成功后将绑定当前微信</text>
    </view>
  </view>
</view>
