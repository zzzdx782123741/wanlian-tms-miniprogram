<!-- pages/auth/login/login.wxml -->
<view class="login-container">
  <view class="logo-section">
    <view class="logo-placeholder" bindlongpress="onOpenTestLogin">
      <text class="logo-text">万联</text>
    </view>
    <text class="app-name">万联驿站2.0</text>
    <text class="app-slogan">智慧物流管理系统</text>
  </view>

  <view class="login-section">
    <button
      class="wechat-login-btn"
      open-type="getUserInfo"
      bindgetuserinfo="onGetUserInfo"
      disabled="{{loading}}"
    >
      <text class="wechat-label">微信一键登录</text>
    </button>

    <view class="tips">
      <text class="tips-text">登录即表示同意</text>
      <text class="link-text">《用户协议》</text>
      <text class="tips-text">和</text>
      <text class="link-text">《隐私政策》</text>
    </view>
  </view>

  <view class="test-login-mask" wx:if="{{showTestLogin}}" bindtap="onCloseTestLogin">
    <view class="test-login-panel" catchtap="noop">
      <view class="test-login-title">测试登录</view>
      <view class="test-login-subtitle">仅开发/测试环境可用</view>

      <input
        class="test-input"
        placeholder="请输入测试账号"
        value="{{testUsername}}"
        bindinput="onTestUsernameInput"
      />
      <input
        class="test-input"
        type="password"
        placeholder="请输入测试密码"
        value="{{testPassword}}"
        bindinput="onTestPasswordInput"
      />

      <view class="test-actions">
        <button class="test-cancel-btn" bindtap="onCloseTestLogin">取消</button>
        <button class="test-submit-btn" loading="{{testLoading}}" disabled="{{testLoading}}" bindtap="onTestLogin">登录</button>
      </view>
    </view>
  </view>
</view>
