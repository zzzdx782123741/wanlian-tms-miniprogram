<!-- pages/auth/login/login.wxml -->
<view class="login-container">
  <view class="logo-section">
    <view class="logo-placeholder" bindlongpress="onOpenTestLogin">
      <text class="logo-text">万联</text>
    </view>
    <text class="app-name">万联驿站 2.0</text>
    <text class="app-slogan">智慧物流管理系统</text>
  </view>

  <view class="login-section">
    <button
      class="wechat-login-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      disabled="{{loading}}"
    >
      <text class="wechat-label">微信手机号快捷登录</text>
    </button>

    <view class="tips">
      <text class="tips-text">登录即表示您已同意</text>
      <text class="link-text">《用户协议》</text>
      <text class="tips-text">和</text>
      <text class="link-text">《隐私政策》</text>
    </view>
  </view>

  <view class="test-login-mask" wx:if="{{showTestLogin}}" bindtap="onCloseTestLogin">
    <view class="test-login-panel" catchtap="noop">
      <view class="test-login-header">
        <view class="test-login-title">🚀 快速测试登录</view>
        <view class="test-login-subtitle">选择角色后快速登录</view>
      </view>

      <view class="test-account-list">
        <view
          class="test-account-item {{testLoading ? 'loading' : ''}}"
          wx:for="{{testAccounts}}"
          wx:key="username"
          bindtap="onQuickLogin"
          data-account="{{item}}"
        >
          <view class="account-icon">{{item.icon}}</view>
          <view class="account-info">
            <view class="account-nickname">{{item.nickname}}</view>
            <view class="account-username">{{item.username}}</view>
          </view>
          <view class="account-arrow">→</view>
        </view>
      </view>

      <view class="test-login-footer">
        <view class="password-tip">测试密码统一为：Test123456</view>
      </view>
    </view>
  </view>
</view>
