/* pages/auth/login/login.wxss */
@import "../../../styles/design-system.wxss";

page {
  height: 100%;
  overflow: hidden;
}

.login-container {
  height: 100%;
  min-height: 100%;
  padding: 48rpx var(--spacing-xl) calc(72rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.logo-section {
  margin-bottom: var(--spacing-3xl);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-xl);
  margin-bottom: var(--spacing-md);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 64rpx;
  font-weight: var(--font-weight-bold);
  color: #FFFFFF;
}

.app-name {
  font-size: var(--font-size-3xl);
  font-weight: var(--font-weight-bold);
  color: #FFFFFF;
  margin-bottom: var(--spacing-xs);
}

.app-slogan {
  font-size: var(--font-size-base);
  color: rgba(255, 255, 255, 0.82);
}

.login-section {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login-btn {
  width: 100%;
  min-height: 108rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #07C160;
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-login-btn[disabled] {
  background: #CCCCCC;
  opacity: 0.7;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn text {
  white-space: nowrap;
  word-break: keep-all;
  word-wrap: normal;
}

.wechat-label {
  display: block;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
  text-align: center;
  max-width: 100%;
}

.tips {
  margin-top: var(--spacing-lg);
  text-align: center;
  font-size: var(--font-size-xs);
}

.tips-text {
  color: rgba(255, 255, 255, 0.74);
}

.link-text {
  color: rgba(255, 255, 255, 0.95);
}

.test-login-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.test-login-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.test-login-title {
  font-size: 34rpx;
  color: #1F2937;
  font-weight: 700;
}

.test-login-subtitle {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.test-input {
  width: 100%;
  height: 84rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  box-sizing: border-box;
  font-size: 28rpx;
}

.test-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.test-cancel-btn,
.test-submit-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.test-cancel-btn {
  background: #F3F4F6;
  color: #374151;
}

.test-submit-btn {
  background: #3B82F6;
  color: #FFFFFF;
}

.test-cancel-btn::after,
.test-submit-btn::after {
  border: none;
}

/* 测试账号列表样式 */
.test-login-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.test-account-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.test-account-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s;
}

.test-account-item:last-child {
  margin-bottom: 0;
}

.test-account-item:active {
  background: #EFF6FF;
  border-color: #3B82F6;
  transform: scale(0.98);
}

.test-account-item.loading {
  opacity: 0.6;
  pointer-events: none;
}

.account-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.account-info {
  flex: 1;
}

.account-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.account-username {
  font-size: 24rpx;
  color: #6B7280;
}

.account-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
  margin-left: 16rpx;
}

.test-login-footer {
  margin-top: 24rpx;
  text-align: center;
}

.password-tip {
  font-size: 24rpx;
  color: #6B7280;
  padding: 12rpx 24rpx;
  background: #FEF3C7;
  border-radius: 8rpx;
  display: inline-block;
}

