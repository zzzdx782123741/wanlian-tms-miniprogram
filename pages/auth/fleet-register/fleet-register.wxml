<!--pages/auth/fleet-register/fleet-register.wxml-->
<view class="fleet-register-container">
  <!-- 顶部标题 -->
  <view class="header-section">
    <text class="header-title">车队注册</text>
    <text class="header-subtitle">完成以下步骤，加入万联驿站2.0</text>
  </view>

  <!-- 步骤指示器 -->
  <view class="steps-container">
    <view class="steps-wrapper">
      <view class="step-item" wx:for="{{steps}}" wx:key="index">
        <view class="step-circle {{currentStep >= index ? 'active' : ''}}">
          <text wx:if="{{currentStep > index}}">✓</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <view class="step-line" wx:if="{{index < steps.length - 1}}" class="{{currentStep > index ? 'active' : ''}}"></view>
      </view>
    </view>
    <view class="step-labels">
      <text class="step-label {{currentStep === index ? 'active' : ''}}" wx:for="{{steps}}" wx:key="index">{{item}}</text>
    </view>
  </view>

  <!-- 步骤1：基本信息 -->
  <view class="form-container" wx:if="{{currentStep === 0}}">
    <view class="form-card glass-card">
      <view class="card-title">基本信息</view>

      <view class="form-item">
        <text class="label required">车队名称</text>
        <input class="input-field" placeholder="请输入车队名称" value="{{formData.name}}" bindinput="onNameInput" />
      </view>

      <view class="form-item">
        <text class="label required">车队类型</text>
        <picker class="picker" mode="selector" range="{{fleetTypes}}" range-key="label" value="{{fleetTypeIndex}}" bindchange="onFleetTypeChange">
          <view class="picker-text">{{fleetTypes[fleetTypeIndex].label}}</view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label required">统一社会信用代码</text>
        <input class="input-field" placeholder="请输入18位统一社会信用代码" maxlength="18" value="{{formData.creditCode}}" bindinput="onCreditCodeInput" />
      </view>

      <view class="form-item">
        <text class="label">经营范围</text>
        <textarea class="textarea-field" placeholder="请简要描述经营范围" value="{{formData.businessScope}}" bindinput="onBusinessScopeInput" maxlength="200" />
      </view>

      <view class="form-item">
        <text class="label required">联系人姓名</text>
        <input class="input-field" placeholder="请输入联系人姓名" value="{{formData.contact.name}}" bindinput="onContactNameInput" />
      </view>

      <view class="form-item">
        <text class="label required">联系人电话</text>
        <input class="input-field" type="number" placeholder="请输入联系人电话" value="{{formData.contact.phone}}" bindinput="onContactPhoneInput" />
      </view>

      <view class="form-item">
        <text class="label">邮箱地址</text>
        <input class="input-field" placeholder="请输入邮箱地址" value="{{formData.contact.email}}" bindinput="onContactEmailInput" />
      </view>
    </view>
  </view>

  <!-- 步骤2：法人信息 -->
  <view class="form-container" wx:if="{{currentStep === 1}}">
    <view class="form-card glass-card">
      <view class="card-title">法人信息</view>

      <view class="form-item">
        <text class="label required">法人代表姓名</text>
        <input class="input-field" placeholder="请输入法人代表姓名" value="{{formData.legalRepresentative.name}}" bindinput="onLegalNameInput" />
      </view>

      <view class="form-item">
        <text class="label required">法人身份证号</text>
        <input class="input-field" placeholder="请输入法人身份证号" maxlength="18" value="{{formData.legalRepresentative.idCard}}" bindinput="onLegalIdCardInput" />
      </view>

      <view class="form-item">
        <text class="label required">法人手机号</text>
        <input class="input-field" type="number" placeholder="请输入法人手机号" value="{{formData.legalRepresentative.phone}}" bindinput="onLegalPhoneInput" />
      </view>
    </view>
  </view>

  <!-- 步骤3：资质材料 -->
  <view class="form-container" wx:if="{{currentStep === 2}}">
    <view class="form-card glass-card">
      <view class="card-title">资质材料</view>

      <view class="form-item">
        <text class="label required">营业执照号码</text>
        <input class="input-field" placeholder="请输入营业执照号码" value="{{formData.businessLicense.number}}" bindinput="onLicenseNumberInput" />
      </view>

      <view class="form-item">
        <text class="label required">营业执照照片</text>
        <view class="upload-section">
          <button class="upload-btn" wx:if="{{!formData.businessLicense.url}}" bindtap="chooseBusinessLicense">
            <text class="icon">📷</text>
            <text>点击上传</text>
          </button>
          <view class="uploaded-preview" wx:else>
            <image class="preview-image" src="{{formData.businessLicense.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{formData.businessLicense.url}}" />
            <view class="remove-btn" bindtap="removeBusinessLicense">✕</view>
          </view>
          <text class="upload-tip">支持jpg/png格式，大小不超过5MB</text>
        </view>
      </view>

      <view class="form-item">
        <text class="label">道路运输许可证号</text>
        <input class="input-field" placeholder="选填，如有请填写" value="{{formData.transportLicense.number}}" bindinput="onTransportNumberInput" />
      </view>

      <view class="form-item">
        <text class="label">道路运输许可证</text>
        <view class="upload-section">
          <button class="upload-btn" wx:if="{{!formData.transportLicense.url}}" bindtap="chooseTransportLicense">
            <text class="icon">📷</text>
            <text>点击上传</text>
          </button>
          <view class="uploaded-preview" wx:else>
            <image class="preview-image" src="{{formData.transportLicense.url}}" mode="aspectFill" bindtap="previewImage" data-url="{{formData.transportLicense.url}}" />
            <view class="remove-btn" bindtap="removeTransportLicense">✕</view>
          </view>
          <text class="upload-tip">选填，支持jpg/png格式，大小不超过5MB</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 步骤4：管理员账号 -->
  <view class="form-container" wx:if="{{currentStep === 3}}">
    <view class="form-card glass-card">
      <view class="card-title">管理员账号</view>

      <view class="tips-info">
        <text class="tips-icon">ℹ️</text>
        <text class="tips-text">请填写车队管理员账号信息，审核通过后将使用此账号登录系统</text>
      </view>

      <view class="form-item">
        <text class="label required">登录账号</text>
        <input class="input-field" type="number" placeholder="请输入手机号作为登录账号" value="{{formData.adminPhone}}" bindinput="onAdminPhoneInput" />
      </view>

      <view class="form-item">
        <text class="label required">管理员姓名</text>
        <input class="input-field" placeholder="请输入管理员姓名" value="{{formData.adminName}}" bindinput="onAdminNameInput" />
      </view>

      <view class="form-item">
        <text class="label">详细地址</text>
        <textarea class="textarea-field" placeholder="请输入详细地址" value="{{formData.address.detail}}" bindinput="onAddressInput" />
      </view>
    </view>
  </view>

  <!-- 步骤5：确认提交 -->
  <view class="form-container" wx:if="{{currentStep === 4}}">
    <view class="form-card glass-card">
      <view class="card-title">确认信息</view>

      <view class="confirm-section">
        <view class="confirm-item">
          <text class="confirm-label">车队名称</text>
          <text class="confirm-value">{{formData.name}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">车队类型</text>
          <text class="confirm-value">{{fleetTypes[fleetTypeIndex].label}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">统一社会信用代码</text>
          <text class="confirm-value">{{formData.creditCode}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">法人代表</text>
          <text class="confirm-value">{{formData.legalRepresentative.name}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">法人身份证</text>
          <text class="confirm-value">{{formData.legalRepresentative.idCard}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">联系人</text>
          <text class="confirm-value">{{formData.contact.name}} / {{formData.contact.phone}}</text>
        </view>

        <view class="confirm-item">
          <text class="confirm-label">管理员账号</text>
          <text class="confirm-value">{{formData.adminPhone}}</text>
        </view>
      </view>

      <view class="agreement-section">
        <checkbox-group bindchange="onAgreementChange">
          <label class="agreement-label">
            <checkbox value="agree" checked="{{agreedToTerms}}" />
            <text>我已阅读并同意《万联驿站车队注册协议》</text>
          </label>
        </checkbox-group>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn secondary" wx:if="{{currentStep > 0}}" bindtap="handlePrev">上一步</button>
    <button class="action-btn primary" wx:if="{{currentStep < 4}}" bindtap="handleNext">下一步</button>
    <button class="action-btn primary" wx:if="{{currentStep === 4}}" loading="{{submitting}}" bindtap="handleSubmit">提交注册</button>
  </view>
</view>
